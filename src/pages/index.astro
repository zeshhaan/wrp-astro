---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import Schema from '../components/Schema.astro';
import { Icon } from 'astro-icon/components';
import LatestPosts from '../components/LatestPosts.astro';
import HeroTestimonials from '../components/reviews/HeroTestimonials.astro';
import { getReviewsForService, getDisplayCount } from '@/lib/reviews';
import { getLocale, localizeUrl, toLocalNum as _toLocalNum } from '@/i18n/utils';
import { t } from '@/i18n/translations';

const locale = getLocale(Astro.currentLocale);

// Get a real review for the inline polish testimonial
const polishReviews = getReviewsForService('polish');
const inlineReview = polishReviews.find(r => r.highlightQuote) || polishReviews[0];
const displayCount = getDisplayCount();
const toLocalNum = (n: string | number) => _toLocalNum(n, locale);

const title = locale === 'ar'
  ? 'WRP Detailing Studio | فيلم حماية الطلاء (PPF)، طلاء سيراميك وتلميع سيارات'
  : 'WRP Detailing Studio | Paint Protection Film (PPF), Ceramic Coating & Detailing';
const description = locale === 'ar'
  ? 'خبراء حماية الطلاء في دبي لفيلم حماية الطلاء (PPF)، طلاء السيراميك، تظليل النوافذ، تلميع السيارات، والعناية بالتنجيد. تركيب دقيق مع ضمان حتى 10 سنوات.'
  : "Dubai's paint protection experts for Paint Protection Film (PPF), ceramic coating, window tinting, car polish, and upholstery care. Precision installation with up to 10-year warranty.";

const heroLines = t(locale, 'home.heroTitle').split('\n');
const philosophyLines = t(locale, 'home.philosophy.title').split('\n');
const aboutLines = t(locale, 'home.about.title').split('\n');
---

<BaseLayout title={title} description={description}>
  <Schema type="WebSite" />
  <Schema type="ServiceCatalog" />

  <div class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 bg-black" id="hero-bg">
        <img
          src="/luxury-supercar-close-up-detail-black-and-white.jpg"
          alt="Luxury supercar receiving premium ceramic coating and paint protection at WRP Detailing Studio detailing studio"
          width="1920"
          height="1080"
          class="w-full h-full object-cover opacity-40"
          id="hero-image"
          loading="eager"
        />
      </div>
      <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold mb-6 text-white tracking-tight">
          {heroLines[0]}
          <br />
          {heroLines[1]}
        </h1>
        <p class="text-lg md:text-xl text-white/90 mb-8 max-w-2xl mx-auto tracking-wide leading-relaxed">
          {t(locale, 'home.heroSubtitle')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button size="lg" className="bg-white text-black hover:bg-white/90 text-base tracking-wide cursor-pointer" data-contact-modal>
            {t(locale, 'home.hero.getQuote')}
            <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
          </Button>
          <a href={localizeUrl('/portfolio/', locale)} class="w-full sm:w-auto">
            <Button
              size="lg"
              variant="outline"
              className="w-full border-white text-white hover:bg-white hover:text-black text-base tracking-wide bg-transparent"
            >
              {t(locale, 'home.hero.viewPortfolio')}
            </Button>
          </a>
        </div>

        <!-- Google Reviews Trust Signal -->
        <a href="https://dub.sh/wrp-map" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-8 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3.5 h-3.5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-sm text-white">
            <span class="font-bold">{toLocalNum('5.0')}</span>
            <span class="text-white/70">{t(locale, 'home.hero.from')}</span>
            <span class="font-bold">{toLocalNum(displayCount)}</span>
            <span class="text-white/70">{t(locale, 'home.hero.reviews')}</span>
          </span>
        </a>
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <Icon name="lucide:chevron-down" class="h-8 w-8 text-white/60" />
      </div>
    </section>

    <!-- Philosophy Section -->
    <section class="py-32 px-6">
      <div class="container mx-auto max-w-6xl">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="font-serif text-5xl md:text-6xl font-bold mb-6 leading-tight">
              {philosophyLines[0]}
              <br />
              {philosophyLines[1]}
            </h2>
            <p class="text-lg text-muted-foreground leading-relaxed mb-6">
              {t(locale, 'home.philosophy.p1')}
            </p>
            <p class="text-lg text-muted-foreground leading-relaxed">
              {t(locale, 'home.philosophy.p2Start')} <a href={localizeUrl('/more-about-wrp/', locale)} class="text-foreground font-medium hover:underline underline-offset-4 transition-all">{t(locale, 'home.philosophy.discoverStory')}</a> {t(locale, 'home.philosophy.p2End')}
            </p>
          </div>
          <div class="relative h-[600px]">
            <img
              src="/luxury-car-detailing-studio-interior-minimal-black.jpg"
              alt="WRP Detailing Studio premium car detailing studio interior with professional equipment and climate-controlled environment"
              width="1200"
              height="800"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-32 px-6 bg-muted/30">
      <div class="container mx-auto max-w-7xl">
        <div class="text-center mb-20">
          <h2 class="font-serif text-5xl md:text-6xl font-bold mb-6">{t(locale, 'home.pillars.title')}</h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            {t(locale, 'home.pillars.subtitle')}
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <Card className="p-8 hover:shadow-2xl transition-shadow duration-300 border-2">
            <div class="mb-6">
              <div class="w-16 h-16 bg-primary text-primary-foreground flex items-center justify-center text-2xl font-bold mb-4">
                W
              </div>
              <h3 class="font-serif text-3xl font-bold mb-3">{t(locale, 'home.pillars.wrap.title')}</h3>
              <p class="text-muted-foreground leading-relaxed">
                {t(locale, 'home.pillars.wrap.desc')}
              </p>
            </div>
            <ul class="space-y-2 text-sm mb-6">
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.wrap.item1')}</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.wrap.item2')}</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.wrap.item3')}</span>
              </li>
            </ul>
            <a href={localizeUrl('/wrap/', locale)}>
              <Button variant="outline" className="w-full bg-transparent">
                {t(locale, 'home.pillars.learnMore')}
              </Button>
            </a>
          </Card>

          <Card className="p-8 hover:shadow-2xl transition-shadow duration-300 border-2">
            <div class="mb-6">
              <div class="w-16 h-16 bg-primary text-primary-foreground flex items-center justify-center text-2xl font-bold mb-4">
                R
              </div>
              <h3 class="font-serif text-3xl font-bold mb-3">{t(locale, 'home.pillars.reinforce.title')}</h3>
              <p class="text-muted-foreground leading-relaxed">
                {t(locale, 'home.pillars.reinforce.desc')}
              </p>
            </div>
            <ul class="space-y-2 text-sm mb-6">
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.reinforce.item1')}</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.reinforce.item2')}</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.reinforce.item3')}</span>
              </li>
            </ul>
            <a href={localizeUrl('/reinforce/', locale)}>
              <Button variant="outline" className="w-full bg-transparent">
                {t(locale, 'home.pillars.learnMore')}
              </Button>
            </a>
          </Card>

          <Card className="p-8 hover:shadow-2xl transition-shadow duration-300 border-2">
            <div class="mb-6">
              <div class="w-16 h-16 bg-primary text-primary-foreground flex items-center justify-center text-2xl font-bold mb-4">
                P
              </div>
              <h3 class="font-serif text-3xl font-bold mb-3">{t(locale, 'home.pillars.protect.title')}</h3>
              <p class="text-muted-foreground leading-relaxed">
                {t(locale, 'home.pillars.protect.desc')}
              </p>
            </div>
            <ul class="space-y-2 text-sm mb-6">
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.protect.item1')}</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.protect.item2')}</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>{t(locale, 'home.pillars.protect.item3')}</span>
              </li>
            </ul>
            <a href={localizeUrl('/protect/', locale)}>
              <Button variant="outline" className="w-full bg-transparent">
                {t(locale, 'home.pillars.learnMore')}
              </Button>
            </a>
          </Card>
        </div>
      </div>
    </section>

    <!-- Our Services Section -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-20">
          <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4">{t(locale, 'home.servicesTitle')}</h2>
          <p class="text-lg text-muted-foreground">
            {t(locale, 'home.servicesSubtitle')}
          </p>
        </div>

        <!-- Service 1: Ceramic Coating - Photo RIGHT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 mb-24">
          <div class="lg:pt-4 lg:pr-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">{t(locale, 'home.services.ceramic.title')}</h3>
              <p class="text-lg text-muted-foreground mb-8">
                {t(locale, 'home.services.ceramic.desc')}
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:shield" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.ceramic.feat1')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.ceramic.feat1Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:droplets" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.ceramic.feat2')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.ceramic.feat2Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:clock" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.ceramic.feat3')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.ceramic.feat3Desc')}</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href={localizeUrl('/services/ceramic-coating/', locale)}>
                  <Button size="lg">
                    {t(locale, 'home.services.exploreService')}
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>
              </div>
            </div>
          </div>
          <div class="overflow-hidden">
            <img src="/portfolio/team-detailing-black-lexus-hood.webp" alt="WRP Detailing Studio technician applying professional ceramic coating on Lexus luxury vehicle hood" width="1200" height="800" class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105" />
          </div>
        </div>

        <!-- Service 2: Paint Protection Film - Photo LEFT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 mb-24 bg-muted/30">
          <div class="flex items-start justify-end lg:order-first overflow-hidden">
            <img src="/portfolio/porsche-boxster-spyder-gray.webp" alt="Porsche Boxster Spyder with paint protection film installation at WRP Detailing Studio showroom" width="1200" height="800" class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105" />
          </div>
          <div class="lg:ml-auto lg:pt-4 lg:pl-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">{t(locale, 'home.services.ppf.title')}</h3>
              <p class="text-lg text-muted-foreground mb-8">
                {t(locale, 'home.services.ppf.desc')}
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:shield-check" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.ppf.feat1')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.ppf.feat1Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:rotate-cw" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.ppf.feat2')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.ppf.feat2Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sun" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.ppf.feat3')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.ppf.feat3Desc')}</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href={localizeUrl('/services/paint-protection-film/', locale)}>
                  <Button size="lg">
                    {t(locale, 'home.services.exploreService')}
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Service 3: Paint Correction - Photo RIGHT with Testimonial -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start mb-24">
          <div class="lg:pt-4 lg:pr-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">{t(locale, 'home.services.polish.title')}</h3>
              <p class="text-lg text-muted-foreground mb-8">
                {t(locale, 'home.services.polish.desc')}
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sparkles" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.polish.feat1')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.polish.feat1Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:eraser" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.polish.feat2')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.polish.feat2Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:gauge" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.polish.feat3')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.polish.feat3Desc')}</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href={localizeUrl('/services/polish/', locale)}>
                  <Button size="lg">
                    {t(locale, 'home.services.exploreService')}
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>
              </div>
              {inlineReview && (
                <figure class="mt-12 border-s-2 border-border ps-8">
                  <blockquote class="text-base text-muted-foreground italic">
                    <p>"{inlineReview.highlightQuote || inlineReview.text.split('.').slice(0, 2).join('.') + '.'}"</p>
                  </blockquote>
                  <figcaption class="mt-4 flex gap-x-4 text-sm">
                    <div>
                      <span class="font-semibold">{inlineReview.reviewerName}</span>
                      <span class="text-muted-foreground"> – {t(locale, 'reviews.verified')}</span>
                    </div>
                  </figcaption>
                </figure>
              )}
            </div>
          </div>
          <div class="overflow-hidden">
            <img src="/portfolio/green-porsche-911-showroom-event.webp" alt="Green Porsche 911 showcasing mirror-finish paint correction and ceramic coating at WRP Detailing Studio" width="1200" height="800" class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105" />
          </div>
        </div>

        <!-- Service 4: Window Film - Photo LEFT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 mb-24 bg-muted/30">
          <div class="flex items-start justify-end lg:order-first overflow-hidden">
            <img src="/portfolio/black-lexus-lx-570-showroom.webp" alt="Lexus LX 570 with professional window tinting and ceramic coating completed at WRP Detailing Studio" width="1200" height="800" class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105" />
          </div>
          <div class="lg:ml-auto lg:pt-4 lg:pl-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">{t(locale, 'home.services.window.title')}</h3>
              <p class="text-lg text-muted-foreground mb-8">
                {t(locale, 'home.services.window.desc')}
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sun" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.window.feat1')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.window.feat1Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:eye-off" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.window.feat2')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.window.feat2Desc')}</dd>
                </div>
                <div class="relative ps-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:signal" class="absolute top-1 start-1 h-5 w-5" />
                    {t(locale, 'home.services.window.feat3')}
                  </dt>
                  <dd class="inline">{t(locale, 'home.services.window.feat3Desc')}</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href={localizeUrl('/services/window-film/', locale)}>
                  <Button size="lg">
                    {t(locale, 'home.services.exploreService')}
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>

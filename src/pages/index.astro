---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from "@/components/ui/button";
import { Card } from "@/components/ui/card";
import Schema from '../components/Schema.astro';
import { Icon } from 'astro-icon/components';
import LatestPosts from '../components/LatestPosts.astro';

const title = 'WRP Dubai | PPF, Ceramic Coating & Paint Protection Experts';
const description = "Dubai's paint protection experts. PPF, ceramic coating & detailing with 10-year warranty. Precision installation for luxury vehicles. Get a free quote today.";
---

<BaseLayout title={title} description={description}>
  <Schema type="WebSite" />

  <div class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="relative h-screen flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 bg-black" id="hero-bg">
        <img
          src="/luxury-supercar-close-up-detail-black-and-white.jpg"
          alt="Luxury supercar receiving premium ceramic coating and paint protection at WRP Dubai detailing studio"
          width="1920"
          height="1080"
          class="w-full h-full object-cover opacity-40"
          id="hero-image"
          loading="eager"
        />
      </div>
      <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold mb-6 text-white tracking-tight">
          Dubai's Paint
          <br />
          Protection Experts
        </h1>
        <p class="text-lg md:text-xl text-white/90 mb-8 max-w-2xl mx-auto tracking-wide leading-relaxed">
          10-Year Warranty. Precision Installation. Flawless Results.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button size="lg" className="bg-white text-black hover:bg-white/90 text-base tracking-wide cursor-pointer" data-contact-modal>
            GET A QUOTE
            <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
          </Button>
          <a href="/portfolio/">
            <Button
              size="lg"
              variant="outline"
              className="border-white text-white hover:bg-white hover:text-black text-base tracking-wide bg-transparent"
            >
              VIEW PORTFOLIO
            </Button>
          </a>
        </div>

        <!-- Google Reviews Trust Signal -->
        <a href="https://dub.sh/wrp-map" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-8 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3.5 h-3.5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-sm text-white">
            <span class="font-bold">5.0</span>
            <span class="text-white/70">from</span>
            <span class="font-bold">60+</span>
            <span class="text-white/70">reviews</span>
          </span>
        </a>
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <Icon name="lucide:chevron-down" class="h-8 w-8 text-white/60" />
      </div>
    </section>

    <!-- Philosophy Section -->
    <section class="py-32 px-6">
      <div class="container mx-auto max-w-6xl">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="font-serif text-5xl md:text-6xl font-bold mb-6 leading-tight">
              Automotive
              <br />
              Excellence
            </h2>
            <p class="text-lg text-muted-foreground leading-relaxed mb-6">
              At WRP., we don't just detail vehicles—we elevate them to works of art. Every surface, every curve,
              every detail receives the meticulous attention it deserves.
            </p>
            <p class="text-lg text-muted-foreground leading-relaxed">
              Our studio in the heart of Dubai serves the region's most discerning automotive enthusiasts, offering
              bespoke protection and enhancement services that set new standards in luxury vehicle care. <a href="/more-about-wrp/" class="text-foreground font-medium hover:underline underline-offset-4 transition-all">Discover our story</a> and the passion that drives every detail.
            </p>
          </div>
          <div class="relative h-[600px]">
            <img
              src="/luxury-car-detailing-studio-interior-minimal-black.jpg"
              alt="WRP Dubai premium car detailing studio interior with professional equipment and climate-controlled environment"
              width="1200"
              height="800"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-32 px-6 bg-muted/30">
      <div class="container mx-auto max-w-7xl">
        <div class="text-center mb-20">
          <h2 class="font-serif text-5xl md:text-6xl font-bold mb-6">The WRP Philosophy</h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            Three pillars of automotive excellence: Wrap, Reinforce, Protect
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <Card className="p-8 hover:shadow-2xl transition-shadow duration-300 border-2">
            <div class="mb-6">
              <div class="w-16 h-16 bg-primary text-primary-foreground flex items-center justify-center text-2xl font-bold mb-4">
                W
              </div>
              <h3 class="font-serif text-3xl font-bold mb-3">Wrap</h3>
              <p class="text-muted-foreground leading-relaxed">
                Premium vinyl wrapping and color transformation. From subtle elegance to bold statements, we bring
                your vision to life with precision application.
              </p>
            </div>
            <ul class="space-y-2 text-sm mb-6">
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Full vehicle color change</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Custom design wraps</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Chrome delete & accents</span>
              </li>
            </ul>
            <a href="/wrap/">
              <Button variant="outline" className="w-full bg-transparent">
                LEARN MORE
              </Button>
            </a>
          </Card>

          <Card className="p-8 hover:shadow-2xl transition-shadow duration-300 border-2">
            <div class="mb-6">
              <div class="w-16 h-16 bg-primary text-primary-foreground flex items-center justify-center text-2xl font-bold mb-4">
                R
              </div>
              <h3 class="font-serif text-3xl font-bold mb-3">Reinforce</h3>
              <p class="text-muted-foreground leading-relaxed">
                Advanced paint protection film and ceramic coating systems. Military-grade protection that preserves
                your investment for years to come.
              </p>
            </div>
            <ul class="space-y-2 text-sm mb-6">
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Paint protection film (PPF)</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Ceramic coating systems</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Nano-technology treatments</span>
              </li>
            </ul>
            <a href="/reinforce/">
              <Button variant="outline" className="w-full bg-transparent">
                LEARN MORE
              </Button>
            </a>
          </Card>

          <Card className="p-8 hover:shadow-2xl transition-shadow duration-300 border-2">
            <div class="mb-6">
              <div class="w-16 h-16 bg-primary text-primary-foreground flex items-center justify-center text-2xl font-bold mb-4">
                P
              </div>
              <h3 class="font-serif text-3xl font-bold mb-3">Protect</h3>
              <p class="text-muted-foreground leading-relaxed">
                Comprehensive detailing and maintenance programs. Meticulous care that maintains showroom perfection,
                inside and out.
              </p>
            </div>
            <ul class="space-y-2 text-sm mb-6">
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Exterior & interior detailing</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Paint correction & polishing</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="lucide:check" class="h-4 w-4 text-primary mt-1 flex-shrink-0" />
                <span>Maintenance programs</span>
              </li>
            </ul>
            <a href="/protect/">
              <Button variant="outline" className="w-full bg-transparent">
                LEARN MORE
              </Button>
            </a>
          </Card>
        </div>
      </div>
    </section>

    <!-- Our Services Section -->
    <section class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-20">
          <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4">Our Services</h2>
          <p class="text-lg text-muted-foreground">
            Premium automotive care solutions for Dubai's luxury vehicles
          </p>
        </div>

        <!-- Service 1: Ceramic Coating - Photo RIGHT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 mb-24">
          <div class="lg:pt-4 lg:pr-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">Ceramic Coating</h3>
              <p class="text-lg text-muted-foreground mb-8">
                Nano-ceramic technology that creates a permanent hydrophobic shield. Delivers unmatched gloss, chemical resistance, and UV protection for years.
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:shield" class="absolute top-1 left-1 h-5 w-5" />
                    9H Hardness Protection.
                  </dt>
                  <dd class="inline">Scratch and swirl resistance with nano-ceramic shield technology</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:droplets" class="absolute top-1 left-1 h-5 w-5" />
                    Hydrophobic Properties.
                  </dt>
                  <dd class="inline">Water beads and rolls off instantly, making washing effortless</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:clock" class="absolute top-1 left-1 h-5 w-5" />
                    2-7 Year Warranty.
                  </dt>
                  <dd class="inline">Long-lasting protection engineered for Dubai's extreme climate</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href="/services/ceramic-coating/">
                  <Button size="lg">
                    EXPLORE SERVICE
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>

              </div>
            </div>
          </div>
          <div class="overflow-hidden">
            <img
              src="/portfolio/team-detailing-black-lexus-hood.webp"
              alt="WRP Dubai technician applying professional ceramic coating on Lexus luxury vehicle hood"
              width="1200"
              height="800"
              class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
        </div>

        <!-- Service 2: Paint Protection Film - Photo LEFT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 mb-24 bg-muted/30">
          <div class="flex items-start justify-end lg:order-first overflow-hidden">
            <img
              src="/portfolio/porsche-boxster-spyder-gray.webp"
              alt="Porsche Boxster Spyder with paint protection film installation at WRP Dubai showroom"
              width="1200"
              height="800"
              class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
          <div class="lg:ml-auto lg:pt-4 lg:pl-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">Paint Protection Film</h3>
              <p class="text-lg text-muted-foreground mb-8">
                Military-grade transparent film that shields your paint from rock chips, scratches, and environmental damage. Self-healing technology repairs minor scratches.
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:shield-check" class="absolute top-1 left-1 h-5 w-5" />
                    Impact Protection.
                  </dt>
                  <dd class="inline">Guards against rock chips, road debris, and minor collisions</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:rotate-cw" class="absolute top-1 left-1 h-5 w-5" />
                    Self-Healing Technology.
                  </dt>
                  <dd class="inline">Minor scratches disappear with heat exposure from sun or water</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sun" class="absolute top-1 left-1 h-5 w-5" />
                    UV Resistance.
                  </dt>
                  <dd class="inline">Prevents paint fading and oxidation from Dubai's intense sunlight</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href="/services/paint-protection-film/">
                  <Button size="lg">
                    EXPLORE SERVICE
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>

              </div>
            </div>
          </div>
        </div>

        <!-- Service 3: Paint Correction - Photo RIGHT with Testimonial -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 lg:items-start mb-24">
          <div class="lg:pt-4 lg:pr-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">Paint Correction & Polish</h3>
              <p class="text-lg text-muted-foreground mb-8">
                Multi-stage machine polishing that removes swirl marks, scratches, and oxidation. Restore your paint's original depth and mirror-like clarity.
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sparkles" class="absolute top-1 left-1 h-5 w-5" />
                    Mirror Finish.
                  </dt>
                  <dd class="inline">Deep, reflective gloss that makes paint look better than new</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:eraser" class="absolute top-1 left-1 h-5 w-5" />
                    Defect Removal.
                  </dt>
                  <dd class="inline">Eliminates 85-95% of swirls, scratches, and water spots</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:gauge" class="absolute top-1 left-1 h-5 w-5" />
                    Paint Depth Measurement.
                  </dt>
                  <dd class="inline">Safe correction using precision gauges and professional compounds</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href="/services/polish/">
                  <Button size="lg">
                    EXPLORE SERVICE
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>

              </div>
              <figure class="mt-12 border-l-2 border-border pl-8">
                <blockquote class="text-base text-muted-foreground italic">
                  <p>"Exceptional attention to detail. My Porsche 911 GT3 RS has never looked better. The ceramic coating is flawless."</p>
                </blockquote>
                <figcaption class="mt-4 flex gap-x-4 text-sm">
                  <div><span class="font-semibold">Ahmed Al-Maktoum</span> – <span class="text-muted-foreground">Porsche 911 GT3 RS Owner</span></div>
                </figcaption>
              </figure>
            </div>
          </div>
          <div class="overflow-hidden">
            <img
              src="/portfolio/green-porsche-911-showroom-event.webp"
              alt="Green Porsche 911 showcasing mirror-finish paint correction and ceramic coating at WRP Dubai"
              width="1200"
              height="800"
              class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
        </div>

        <!-- Service 4: Window Film - Photo LEFT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2 mb-24 bg-muted/30">
          <div class="flex items-start justify-end lg:order-first overflow-hidden">
            <img
              src="/portfolio/black-lexus-lx-570-showroom.webp"
              alt="Lexus LX 570 with professional window tinting and ceramic coating completed at WRP Dubai"
              width="1200"
              height="800"
              class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
          <div class="lg:ml-auto lg:pt-4 lg:pl-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">Window Film</h3>
              <p class="text-lg text-muted-foreground mb-8">
                Advanced ceramic technology that blocks 99% UV rays and up to 80% heat. Enhanced privacy and comfort for Dubai's intense climate.
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sun" class="absolute top-1 left-1 h-5 w-5" />
                    Heat Rejection.
                  </dt>
                  <dd class="inline">Block up to 80% of solar heat for cooler cabin temperature</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:eye-off" class="absolute top-1 left-1 h-5 w-5" />
                    Enhanced Privacy.
                  </dt>
                  <dd class="inline">Discreet tinting while maintaining crystal-clear visibility</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:signal" class="absolute top-1 left-1 h-5 w-5" />
                    Signal Safe.
                  </dt>
                  <dd class="inline">Ceramic films won't interfere with GPS, radio, or mobile signals</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href="/services/window-film/">
                  <Button size="lg">
                    EXPLORE SERVICE
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>

              </div>
            </div>
          </div>
        </div>

        <!-- Service 5: Premium Car Wash - Photo RIGHT -->
        <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-2">
          <div class="lg:pt-4 lg:pr-8">
            <div class="lg:max-w-lg">
              <h3 class="font-serif text-3xl md:text-4xl font-bold mb-4">Premium Car Wash</h3>
              <p class="text-lg text-muted-foreground mb-8">
                Meticulous hand-wash service using pH-neutral products, microfiber techniques, and premium wax polish. Professional care that delivers a showroom-shiny finish.
              </p>
              <dl class="space-y-6 text-base text-muted-foreground">
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:hand" class="absolute top-1 left-1 h-5 w-5" />
                    Hand Wash Only.
                  </dt>
                  <dd class="inline">No harsh brushes or automated systems that damage paint</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:sparkles" class="absolute top-1 left-1 h-5 w-5" />
                    Premium Wax Polish.
                  </dt>
                  <dd class="inline">Showroom-shiny finish with protective wax layer application</dd>
                </div>
                <div class="relative pl-9">
                  <dt class="inline font-semibold text-foreground">
                    <Icon name="lucide:droplet" class="absolute top-1 left-1 h-5 w-5" />
                    Spot-Free Finish.
                  </dt>
                  <dd class="inline">Filtered water rinse prevents water spots in Dubai's hard water</dd>
                </div>
              </dl>
              <div class="mt-8">
                <a href="/services/premium-car-wash/">
                  <Button size="lg">
                    EXPLORE SERVICE
                    <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
                  </Button>
                </a>

              </div>
            </div>
          </div>
          <div class="overflow-hidden">
            <img
              src="/portfolio/team-washing-subaru-sti-foam.webp"
              alt="WRP Dubai team performing premium hand car wash with foam treatment on Subaru WRX STI"
              width="1200"
              height="800"
              class="w-full h-auto object-cover transition-transform duration-500 hover:scale-105"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Portfolio Section -->
    <section id="portfolio" class="py-32 px-6">
      <div class="container mx-auto max-w-7xl">
        <div class="text-center mb-20">
          <h2 class="font-serif text-5xl md:text-6xl font-bold mb-6">Portfolio</h2>
          <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
            A showcase of our finest work with the world's most prestigious automobiles
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="relative h-[500px] group overflow-hidden">

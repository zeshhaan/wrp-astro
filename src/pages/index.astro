                  const form = event.target;
                  const defaultError = form.dataset.defaultError || 'Something went wrong';
                  const networkError = form.dataset.networkError || 'Network error. Please try again or call us directly.';

                  try {
                    const formData = new FormData(form);
                    const response = await fetch('/api/contact', {
                      method: 'POST',
                      body: formData
                    });

                    const result = await response.json();

                    if (result.success) {

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GridPattern from '../../components/GridPattern.astro';
import LatestPosts from '../../components/LatestPosts.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Button } from "@/components/ui/button";
import { getLocale, localizeUrl, toLocalNum as _toLocalNum } from '@/i18n/utils';
import { t } from '@/i18n/translations';

export const prerender = true;

const locale = getLocale(Astro.currentLocale);
const toLocalNum = (n: string | number) => _toLocalNum(n, locale);
const siteBase = Astro.site?.toString().replace(/\/$/, '') || 'https://wrpdetailing.ae';
const aboutUrl = `${siteBase}${localizeUrl('/more-about-wrp/', locale)}`;
const breadcrumbs = [
  { name: t(locale, 'common.home'), url: `${siteBase}${localizeUrl('/', locale)}` },
  { name: t(locale, 'nav.about'), url: aboutUrl },
];

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'عن WRP Detailing Studio',
  url: aboutUrl,
  inLanguage: 'ar-AE',
  mainEntity: {
    '@type': 'Organization',
    name: 'WRP Detailing Studio',
    alternateName: 'Wrap, Reinforce, Protect',
    foundingDate: '2010',
    description: 'استوديو دبي المتخصص في حماية وتحسين السيارات الفاخرة بدقة حرفية وخبرة عملية تمتد لسنوات.',
    slogan: 'Wrap, Reinforce, Protect',
    numberOfEmployees: {
      '@type': 'QuantitativeValue',
      value: '10',
    },
  },
};
---

<BaseLayout
  title="عن WRP Detailing Studio | استوديو حماية وتفصيل السيارات الفاخرة"
  description="تعرّف على WRP Detailing Studio. منذ 2010 ونحن نقدّم خدمات حماية وتحسين السيارات الفاخرة بدقة عالية، مواد معتمدة، وحرفية تليق بأغلى السيارات."
>
  <Breadcrumbs crumbs={breadcrumbs} className="container mx-auto px-6 pt-28" />

  <script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />

  <section class="relative flex h-[70vh] items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-black">
      <img
        src="/luxury-car-detailing-studio-interior-minimal-black.jpg"
        alt="استوديو WRP Detailing Studio المجهز للعناية الدقيقة بالسيارات الفاخرة"
        width="1920"
        height="1080"
        class="absolute inset-0 h-full w-full object-cover opacity-50"
      />
    </div>
    <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
      <h1 class="font-serif text-5xl font-bold tracking-tight text-white md:text-7xl">قصة WRP.</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/90 md:text-xl">
        حين يلتقي الشغف بعالم السيارات مع الحرفية الدقيقة والنتائج التي لا تقبل المساومة.
      </p>
    </div>
  </section>

  <section class="px-6 py-32">
    <div class="container mx-auto max-w-6xl">
      <div class="grid items-center gap-16 md:grid-cols-2">
        <div>
          <h2 class="font-serif text-4xl font-bold leading-tight md:text-5xl">
            بدأنا بالشغف،
            <br />
            وبنينا سمعتنا على الإتقان
          </h2>
          <p class="mb-6 mt-6 text-lg leading-relaxed text-muted-foreground">
            تأسست WRP في عام 2010 على يد فريق شغوف بالسيارات أدرك أن سوق العناية بالسيارات الفاخرة في دبي
            يحتاج إلى مستوى أعلى من العناية والانضباط. كنا نرى سيارات استثنائية تتلقى خدمات لا توازي قيمتها ولا
            توقعات ملاكها.
          </p>
          <p class="mb-6 text-lg leading-relaxed text-muted-foreground">
            ما بدأ باستوديو صغير وموقف عمل واحد تحوّل إلى اسم موثوق لدى أصحاب السيارات الفاخرة في دبي. فلسفتنا
            بسيطة: نتعامل مع كل سيارة كما لو كانت تحفة خاصة بنا، ونمنح كل تفصيل الوقت والدقة التي يستحقها.
          </p>
          <p class="text-lg leading-relaxed text-muted-foreground">
            اليوم نخدم هواة الجمع، وعشّاق الأداء، وأصحاب السيارات الذين لا يقبلون إلا بالنتيجة المثالية. من
            السيارات الخارقة النادرة إلى سيارات السيدان الفاخرة المصممة حسب الطلب، قمنا بحماية وتحسين بعض
            السيارات الأكثر قيمة على طرق دبي.
          </p>
        </div>
        <div class="relative h-[600px]">
          <img
            src="/luxury-car-detailing-craftsman-working-black-and-w.jpg"
            alt="فني WRP يعمل بعناية على سيارة فاخرة"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background px-6 py-24 sm:py-32">
    <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
      <div class="mb-16 text-center">
        <h2 class="font-serif text-4xl font-bold text-foreground md:text-5xl">قيمنا الأساسية</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
          المبادئ التي توجه كل خدمة نقدمها وكل سيارة تدخل إلى الاستوديو.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-16 lg:grid-cols-6 lg:grid-rows-2">
        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 bg-card"></div>
          <div class="relative flex h-full flex-col overflow-hidden">
            <img src="/luxury-sports-car-detail-black-and-white-dramatic.jpg" alt="سيارة رياضية فاخرة بعد إنهاء الحماية والتفصيل" width="1200" height="800" class="h-80 object-cover" />
            <div class="p-10 pt-4">
              <p class="text-lg font-medium tracking-tight text-foreground">التميّز</p>
              <p class="mt-2 max-w-lg text-sm/6 text-muted-foreground">
                لا نساوم على الجودة. كل تفصيل مهم، وكل سطح يجب أن يصل إلى أفضل حالة ممكنة، وكل عميل يستحق أفضل ما لدينا.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 shadow-sm outline outline-black/5"></div>
        </div>

        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 bg-card"></div>
          <div class="relative flex h-full flex-col overflow-hidden">
            <img src="/luxury-car-detailing-craftsman-working-black-and-w.jpg" alt="خبير WRP ينفذ تصحيح طلاء بدقة" width="1200" height="800" class="h-80 object-cover lg:object-right" />
            <div class="p-10 pt-4">
              <p class="text-lg font-medium tracking-tight text-foreground">الخبرة</p>
              <p class="mt-2 max-w-lg text-sm/6 text-muted-foreground">
                فريقنا يجمع سنوات من العمل مع أرقى العلامات والسيارات، ويعرف كيف يتعامل مع كل مادة وسطح بالطريقة الصحيحة.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 shadow-sm outline outline-black/5"></div>
        </div>

        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 bg-card"></div>
          <div class="relative flex h-full flex-col overflow-hidden">
            <img src="/supercar-wheel-detail-black-and-white-luxury.jpg" alt="تفصيل دقيق لعجلة سيارة رياضية فاخرة" width="1200" height="800" class="h-80 object-cover object-center" />
            <div class="p-10 pt-4">
              <p class="text-lg font-medium tracking-tight text-foreground">الدقة</p>
              <p class="mt-2 max-w-lg text-sm/6 text-muted-foreground">
                النتائج الكبيرة تأتي من تفاصيل صغيرة. لهذا نتعامل مع كل مرحلة بعناية منهجية وانضباط كامل.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 shadow-sm outline outline-black/5"></div>
        </div>

        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 bg-card"></div>
          <div class="relative flex h-full flex-col overflow-hidden">
            <img src="/luxury-sedan-close-up-black-and-white-elegant.jpg" alt="سيارة سيدان فاخرة تظهر جودة الحماية واللمعان" width="1200" height="800" class="h-80 object-cover" />
            <div class="p-10 pt-4">
              <p class="text-lg font-medium tracking-tight text-foreground">التطوير المستمر</p>
              <p class="mt-2 max-w-lg text-sm/6 text-muted-foreground">
                نستثمر باستمرار في أحدث المواد والتقنيات وأساليب التطبيق لنضمن أن خدماتنا تواكب أفضل ما في السوق.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 shadow-sm outline outline-black/5"></div>
        </div>

        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 bg-card"></div>
          <div class="relative flex h-full flex-col overflow-hidden">
            <img src="/luxury-suv-black-and-white-premium-detail.jpg" alt="سيارة SUV فاخرة بعد خدمة عناية كاملة" width="1200" height="800" class="h-80 object-cover" />
            <div class="p-10 pt-4">
              <p class="text-lg font-medium tracking-tight text-foreground">الالتزام</p>
              <p class="mt-2 max-w-lg text-sm/6 text-muted-foreground">
                نلتزم بما نعد به، ونسعى دائماً إلى تجاوز التوقعات في جودة التنفيذ، ووضوح التواصل، وتجربة العميل بالكامل.
              </p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 shadow-sm outline outline-black/5"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 py-32">
    <div class="container mx-auto max-w-6xl">
      <div class="mb-20 text-center">
        <h2 class="font-serif text-4xl font-bold md:text-5xl">منهج WRP.</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
          خطوات واضحة ومدروسة للوصول إلى نتيجة تليق بسيارتك وتستمر معك.
        </p>
      </div>

      <div class="space-y-16">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <div class="order-2 md:order-1">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-primary-foreground">1</div>
              <div>
                <h3 class="font-serif text-2xl font-bold">الاستشارة والمعاينة</h3>
                <p class="mt-3 leading-relaxed text-muted-foreground">
                  نبدأ بفهم احتياجك الفعلي وطبيعة استخدام السيارة، ثم نجري معاينة دقيقة للحالة الحالية لتحديد أفضل خطة حماية أو تحسين.
                </p>
              </div>
            </div>
          </div>
          <div class="order-1 relative h-[300px] md:order-2">
            <img src="/luxury-sedan-close-up-black-and-white-elegant.jpg" alt="مرحلة المعاينة الأولية للسيارة" class="h-full w-full object-cover" />
          </div>
        </div>

        <div class="grid items-center gap-12 md:grid-cols-2">
          <div class="relative h-[300px]">
            <img src="/luxury-sports-car-detail-black-and-white-dramatic.jpg" alt="مرحلة التحضير وتصحيح الطلاء" class="h-full w-full object-cover" />
          </div>
          <div>
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-primary-foreground">2</div>
              <div>
                <h3 class="font-serif text-2xl font-bold">التحضير وتصحيح الطلاء</h3>
                <p class="mt-3 leading-relaxed text-muted-foreground">
                  يتم تنظيف كل سطح وتجهيزه بعناية. وعند الحاجة، نجري تصحيحاً للطلاء لإزالة العيوب والدوامات والخدوش الخفيفة قبل أي طبقة حماية.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid items-center gap-12 md:grid-cols-2">
          <div class="order-2 md:order-1">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-primary-foreground">3</div>
              <div>
                <h3 class="font-serif text-2xl font-bold">التطبيق والحماية</h3>
                <p class="mt-3 leading-relaxed text-muted-foreground">
                  نستخدم مواد معتمدة وتقنيات متقدمة في تطبيق فيلم حماية الطلاء أو طلاء السيراميك أو غيرها من الخدمات، مع تنفيذ دقيق على يد فنيين متمرسين.
                </p>
              </div>
            </div>
          </div>
          <div class="order-1 relative h-[300px] md:order-2">
            <img src="/supercar-wheel-detail-black-and-white-luxury.jpg" alt="مرحلة تطبيق الحماية على السيارة" class="h-full w-full object-cover" />
          </div>
        </div>

        <div class="grid items-center gap-12 md:grid-cols-2">
          <div class="relative h-[300px]">
            <img src="/luxury-suv-black-and-white-premium-detail.jpg" alt="الفحص النهائي قبل التسليم" class="h-full w-full object-cover" />
          </div>
          <div>
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-primary-foreground">4</div>
              <div>
                <h3 class="font-serif text-2xl font-bold">الفحص النهائي والتسليم</h3>
                <p class="mt-3 leading-relaxed text-muted-foreground">
                  قبل التسليم تمر كل سيارة بفحص جودة شامل للتأكد من أن كل تفصيل مطابق لمعاييرنا. ثم نسلّمك السيارة مع التوصيات والتعليمات المناسبة للعناية بها.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-muted/30 px-6 py-32">
    <div class="container mx-auto max-w-6xl">
      <div class="mb-20 text-center">
        <h2 class="font-serif text-4xl font-bold md:text-5xl">لماذا WRP؟</h2>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
          هذا ما يجعلنا خياراً موثوقاً لدى أصحاب السيارات الفاخرة وعشّاق العناية الدقيقة في دبي.
        </p>
      </div>

      <div class="mb-16 grid gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mb-4 text-6xl font-bold">{toLocalNum('+500')}</div>
          <div class="mb-2 text-xl font-bold">سيارة محمية</div>
          <p class="text-muted-foreground">
            من السيارات الفاخرة اليومية إلى السيارات الخارقة النادرة، قمنا بحماية وتحسين مجموعة واسعة من أبرز السيارات في دبي.
          </p>
        </div>
        <div class="text-center">
          <div class="mb-4 text-6xl font-bold">{toLocalNum('+15')}</div>
          <div class="mb-2 text-xl font-bold">سنة خبرة</div>
          <p class="text-muted-foreground">
            خبرة عملية ممتدة مع أفضل المواد والعلامات والخدمات التي تتطلب دقة عالية ومعايير تنفيذ صارمة.
          </p>
        </div>
        <div class="text-center">
          <div class="mb-4 text-6xl font-bold">{toLocalNum('100%')}</div>
          <div class="mb-2 text-xl font-bold">تركيز على رضا العميل</div>
          <p class="text-muted-foreground">
            من أول تواصل إلى لحظة التسليم، نهتم بالتفاصيل التي تصنع فرقاً حقيقياً في جودة التجربة والنتيجة النهائية.
          </p>
        </div>
      </div>

      <div class="border border-border bg-background p-8">
        <h3 class="font-serif text-2xl font-bold">مواد معتمدة وتقنيات احترافية</h3>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          نستخدم منتجات رائدة من علامات مثل XPEL و3M وGtechniq وAdam&apos;s وغيرها من المصنعين الموثوقين. كما يعمل
          فريقنا داخل بيئة مجهزة بأنظمة قص دقيقة، ومعدات تطبيق احترافية، ومساحات تحضير مصممة لتقديم نتيجة مستقرة ونظيفة.
        </p>
      </div>
    </div>
  </section>

  <LatestPosts
    heading="تعرّف أكثر"
    subheading="اطلع على أدلتنا ومقالاتنا حول حماية السيارة والعناية بها في دبي"
  />

  <section class="relative overflow-hidden bg-primary px-6 py-32 text-center text-primary-foreground">
    <GridPattern />
    <div class="container relative z-10 mx-auto max-w-3xl">
      <h2 class="font-serif text-4xl font-bold">هل أنت جاهز لتجربة WRP؟</h2>
      <p class="mb-8 mt-6 text-xl opacity-90">
        دع فريقنا يوضح لك الخدمة الأنسب لسيارتك ويقترح خطة حماية أو تحسين تناسب أسلوب استخدامك.
      </p>
      <div class="flex flex-col justify-center gap-4 sm:flex-row">
        <Button size="lg" className="cursor-pointer bg-white text-base tracking-wide text-black hover:bg-white/90" data-contact-modal>
          اطلب عرض سعر
        </Button>
        <a href={`${localizeUrl('/', locale)}#services`} class="w-full sm:w-auto">
          <Button
            size="lg"
            variant="outline"
            className="w-full border-white bg-transparent text-base tracking-wide text-white hover:bg-white hover:text-black"
          >
            عرض الخدمات
          </Button>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import GridPattern from '@/components/GridPattern.astro';
import { Card } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Icon } from 'astro-icon/components';
import { getLocale, localizeUrl, toLocalNum as _toLocalNum } from '@/i18n/utils';
import { t } from '@/i18n/translations';
import { getLocalizedBlogPosts } from '@/i18n/content';

export const prerender = true;

const locale = getLocale(Astro.currentLocale);
const toLocalNum = (n: string | number) => _toLocalNum(n, locale);
const posts = (await getLocalizedBlogPosts(locale)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts.find((post) => post.data.featured);
const allPosts = posts;

const siteBase = Astro.site?.toString().replace(/\/$/, '') || 'https://wrpdetailing.ae';
const blogUrl = `${siteBase}${localizeUrl('/blog/', locale)}`;
const breadcrumbs = [
  { name: t(locale, 'common.home'), url: `${siteBase}${localizeUrl('/', locale)}` },
  { name: t(locale, 'blog.title'), url: blogUrl },
];

const categoryLabels: Record<string, string> = {
  guide: 'دليل',
  news: 'أخبار',
  update: 'تحديث',
  event: 'فعالية',
  listicle: 'قائمة',
};

const categories = ['all', 'guide', 'listicle', 'news'] as const;
const categoryFilterLabels: Record<string, string> = {
  all: 'الكل',
  guide: 'أدلة',
  listicle: 'قوائم',
  news: 'أخبار',
};

const categoriesWithPosts = new Set(allPosts.map((p) => p.data.category));
const categoryHasPosts: Record<string, boolean> = {};
for (const cat of categories) {
  categoryHasPosts[cat] = cat === 'all' ? allPosts.length > 0 : categoriesWithPosts.has(cat);
}

const blogListSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'مدونة WRP Detailing Studio',
  description: 'أدلة ونصائح خبراء حول طلاء السيراميك وفيلم حماية الطلاء والعناية بالسيارات في دبي.',
  url: blogUrl,
  inLanguage: 'ar-AE',
  isPartOf: { '@type': 'WebSite', name: 'WRP Detailing Studio', url: `${siteBase}/` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: allPosts.length,
    itemListElement: allPosts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteBase}${localizeUrl(`/blog/${post.id.replace(/^ar\//, '')}/`, locale)}`,
      name: post.data.title,
    })),
  },
};
---

<BaseLayout
  title="المدونة | WRP Detailing Studio - أدلة ونصائح العناية بالسيارات"
  description="مقالات عربية متخصصة عن طلاء السيراميك وفيلم حماية الطلاء والعناية بالسيارات في دبي من خبراء WRP."
>
  <Breadcrumbs crumbs={breadcrumbs} className="container mx-auto px-6 pt-28" />

  <script type="application/ld+json" set:html={JSON.stringify(blogListSchema)} />

  <section class="relative bg-black px-6 py-20 text-white">
    <div class="container mx-auto max-w-7xl text-center">
      <h1 class="mb-6 font-serif text-5xl font-bold md:text-7xl">المدونة</h1>
      <p class="mx-auto max-w-2xl text-lg text-white/70 md:text-xl">
        مقالات وأدلة عملية حول حماية الطلاء، طلاء السيراميك، والعناية بالسيارات بما يناسب أجواء دبي.
      </p>
    </div>
  </section>

  {featuredPost && (
    <section class="bg-muted/30 px-6 py-20">
      <div class="container mx-auto max-w-7xl">
        <div class="mb-8 flex items-center gap-3">
          <div class="h-px flex-1 bg-border"></div>
          <span class="text-xs font-medium uppercase tracking-widest text-muted-foreground">{t(locale, 'blog.featured')}</span>
          <div class="h-px flex-1 bg-border"></div>
        </div>

        <a href={localizeUrl(`/blog/${featuredPost.id.replace(/^ar\//, '')}/`, locale)} class="group block">
          <div class="grid items-center gap-8 md:grid-cols-2">
            {featuredPost.data.heroImage && (
              <div class="relative aspect-[16/9] overflow-hidden rounded-lg">
                <img
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class={featuredPost.data.heroImage ? '' : 'mx-auto max-w-2xl text-center md:col-span-2'}>
              <div class="mb-4 flex items-center gap-2 text-xs text-muted-foreground">
                <span class="bg-foreground/10 px-2 py-1 font-medium uppercase tracking-wider text-foreground">
                  {categoryLabels[featuredPost.data.category] || featuredPost.data.category}
                </span>
                <span class="text-border">·</span>
                <FormattedDate date={featuredPost.data.pubDate} />
                {featuredPost.data.readingTime && (
                  <>
                    <span class="text-border">·</span>
                    <span>{toLocalNum(featuredPost.data.readingTime)} {t(locale, 'blog.minRead')}</span>
                  </>
                )}
              </div>
              <h2 class="mb-4 font-serif text-3xl font-bold underline-offset-4 group-hover:underline md:text-4xl">
                {featuredPost.data.title}
              </h2>
              <p class="mb-6 leading-relaxed text-muted-foreground">
                {featuredPost.data.description}
              </p>
              <span class="inline-flex items-center text-sm font-medium underline-offset-4 group-hover:underline">
                {t(locale, 'blog.readMore')}
                <Icon name="lucide:arrow-right" class="ml-1 h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" />
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="px-6 py-20" x-data={`{ category: 'all', hasPosts: ${JSON.stringify(categoryHasPosts)} }`}>
    <div class="container mx-auto max-w-7xl">
      <div class="mb-12 flex flex-wrap justify-center gap-2">
        {categories.map((cat) => (
          <button
            class="border px-4 py-2 text-sm tracking-wide transition-colors"
            :class={`category === '${cat}' ? 'border-foreground bg-foreground text-background' : 'border-border bg-transparent text-foreground hover:border-foreground'`}
            @click={`category = '${cat}'`}
          >
            {categoryFilterLabels[cat]}
          </button>
        ))}
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {allPosts.map((post) => (
          <a
            href={localizeUrl(`/blog/${post.id.replace(/^ar\//, '')}/`, locale)}
            class="group block"
            x-show={`category === 'all' || category === '${post.data.category}'`}
            x-cloak
          >
            <Card className="h-full overflow-hidden p-0 transition-all duration-300 hover:shadow-lg">
              {post.data.heroImage && (
                <div class="relative aspect-[16/9] overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5">
                <div class="mb-3 flex items-center gap-2 text-xs text-muted-foreground">
                  {post.data.category && (
                    <span class="font-medium uppercase tracking-wider text-foreground">
                      {categoryLabels[post.data.category] || post.data.category}
                    </span>
                  )}
                  {post.data.category && <span class="text-border">·</span>}
                  <FormattedDate date={post.data.pubDate} />
                  {post.data.readingTime && (
                    <>
                      <span class="text-border">·</span>
                      <span>{toLocalNum(post.data.readingTime)} د</span>
                    </>
                  )}
                </div>
                <h3 class="mb-2 font-serif text-lg font-bold leading-snug underline-offset-4 group-hover:underline">
                  {post.data.title}
                </h3>
                <p class="line-clamp-2 text-sm leading-relaxed text-muted-foreground">
                  {post.data.description}
                </p>
                <span class="mt-4 inline-flex items-center text-sm font-medium underline-offset-4 group-hover:underline">
                  {t(locale, 'blog.readMore')}
                  <Icon name="lucide:arrow-right" class="ml-1 h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" />
                </span>
              </div>
            </Card>
          </a>
        ))}
      </div>

      <div x-show="!hasPosts[category]" x-cloak class="py-20 text-center">
        <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-muted">
          <Icon name="lucide:file-text" class="h-7 w-7 text-muted-foreground" />
        </div>
        <h3 class="mb-3 font-serif text-2xl font-bold">لا توجد مقالات بعد</h3>
        <p class="mx-auto mb-6 max-w-md text-muted-foreground">
          نعمل حالياً على إضافة محتوى لهذه الفئة. يمكنك العودة لاحقاً أو استعراض بقية المقالات.
        </p>
        <button
          class="border border-foreground bg-foreground px-6 py-2.5 text-sm tracking-wide text-background transition-colors hover:bg-foreground/90"
          @click="category = 'all'"
        >
          عرض جميع المقالات
        </button>
      </div>

      {allPosts.length === 0 && (
        <div class="py-16 text-center">
          <p class="text-lg text-muted-foreground">لا توجد مقالات منشورة حالياً. عد لاحقاً.</p>
        </div>
      )}
    </div>
  </section>

  <section class="relative overflow-hidden bg-black px-6 py-32 text-white">
    <GridPattern />
    <div class="container relative z-10 mx-auto max-w-4xl text-center">
      <h2 class="mb-6 font-serif text-4xl font-bold md:text-5xl">ابقَ على اطلاع</h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-white/80">
        إذا كانت لديك أسئلة حول حماية سيارتك أو اختيار الخدمة المناسبة لظروف دبي، ففريقنا جاهز لمساعدتك.
      </p>
      <Button size="lg" className="cursor-pointer bg-white text-black hover:bg-white/90" data-contact-modal>
        تواصل معنا
        <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
      </Button>
    </div>
  </section>
</BaseLayout>

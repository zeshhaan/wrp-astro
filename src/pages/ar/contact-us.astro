---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Button } from "@/components/ui/button";
import { Icon } from 'astro-icon/components';
import { getLocale, localizeUrl, toLocalNum as _toLocalNum } from '@/i18n/utils';
import { t } from '@/i18n/translations';

export const prerender = false;

const locale = getLocale(Astro.currentLocale);
const toLocalNum = (n: string | number) => _toLocalNum(n, locale);
const siteBase = Astro.site?.toString().replace(/\/$/, '') || 'https://wrpdetailing.ae';
const contactUrl = `${siteBase}${localizeUrl('/contact-us/', locale)}`;
const breadcrumbs = [
  { name: t(locale, 'common.home'), url: `${siteBase}${localizeUrl('/', locale)}` },
  { name: t(locale, 'nav.contact'), url: contactUrl },
];

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'اتصل بـ WRP Detailing Studio',
  url: contactUrl,
  mainEntity: {
    '@type': 'LocalBusiness',
    name: 'WRP Detailing Studio',
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+971547173000',
      contactType: 'customer service',
      email: 'info@wrpdetailing.ae',
      areaServed: 'AE',
      availableLanguage: ['Arabic', 'English'],
    },
  },
};
---

<BaseLayout
  title="اتصل بـ WRP Detailing Studio | اطلب عرض سعر لخدمات العناية الفاخرة بالسيارات"
  description="تواصل مع WRP Detailing Studio في القصيص للحصول على استشارة وعرض سعر مخصص لخدمات فيلم حماية الطلاء وطلاء السيراميك والتظليل والتلميع."
>
  <Breadcrumbs crumbs={breadcrumbs} className="container mx-auto px-6 pt-28" />

  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <div class="relative isolate bg-background">
    <div class="mx-auto grid max-w-7xl grid-cols-1 lg:grid-cols-2">
      <div class="relative px-6 pb-20 pt-24 sm:pt-32 lg:static lg:px-8 lg:py-48">
        <div class="mx-auto max-w-xl lg:mx-0 lg:max-w-lg">
          <div class="absolute inset-y-0 left-0 -z-10 w-full overflow-hidden bg-muted ring-1 ring-border lg:w-1/2">
            <svg aria-hidden="true" class="absolute inset-0 size-full stroke-border [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]">
              <defs>
                <pattern id="contact-pattern-ar" width="200" height="200" x="100%" y="-1" patternUnits="userSpaceOnUse">
                  <path d="M130 200V.5M.5 .5H200" fill="none" />
                </pattern>
              </defs>
              <rect width="100%" height="100%" stroke-width="0" class="fill-background" />
              <svg x="100%" y="-1" class="overflow-visible fill-muted">
                <path d="M-470.5 0h201v201h-201Z" stroke-width="0" />
              </svg>
              <rect width="100%" height="100%" fill="url(#contact-pattern-ar)" stroke-width="0" />
            </svg>
          </div>

          <h1 class="font-serif text-4xl font-bold tracking-tight text-foreground sm:text-5xl">اطلب عرض سعر</h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            شاركنا تفاصيل سيارتك والخدمة التي تفكر فيها، وسيتواصل فريقنا معك بعرض سعر واضح وخطة تناسب احتياجك.
          </p>

          <dl class="mt-10 space-y-4 text-base leading-7 text-foreground">
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">العنوان</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="h-7 w-6 text-muted-foreground">
                  <path d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </dt>
              <dd>
                <a href="https://dub.sh/wrp-map" target="_blank" rel="noopener noreferrer" class="hover:text-foreground">
                  {t(locale, 'home.contact.address1')}<br />{t(locale, 'home.contact.address2')}
                </a>
              </dd>
            </div>
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">الهاتف</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="h-7 w-6 text-muted-foreground">
                  <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </dt>
              <dd><a href="https://dub.sh/wrp-phone" class="hover:text-foreground">{toLocalNum('+971 54 717 3000')}</a></dd>
            </div>
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">البريد الإلكتروني</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="h-7 w-6 text-muted-foreground">
                  <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </dt>
              <dd><a href="https://dub.sh/wrp-email" class="hover:text-foreground">info@wrpdetailing.ae</a></dd>
            </div>
            <div class="flex gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">إنستغرام</span>
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-7 w-6 text-muted-foreground">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2" fill="none"></rect>
                  <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke="currentColor" stroke-width="2" fill="none"></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="currentColor" stroke-width="2"></line>
                </svg>
              </dt>
              <dd><a href="https://dub.sh/wrp_ig" target="_blank" rel="noopener" class="hover:text-foreground">@wrp_ae</a></dd>
            </div>
          </dl>
        </div>
      </div>

      <form
        data-default-error={t(locale, 'form.error')}
        data-network-error={t(locale, 'home.contact.networkError')}
        x-data="{
          submitting: false,
          success: false,
          error: '',
          async submitForm(event) {
            event.preventDefault();
            this.submitting = true;
            this.error = '';
            const form = event.target;
            const defaultError = form.dataset.defaultError || 'حدث خطأ.';
            const networkError = form.dataset.networkError || 'خطأ في الشبكة. يرجى المحاولة مرة أخرى أو الاتصال بنا مباشرة.';

            try {
              const formData = new FormData(form);
              const response = await fetch('/api/contact', {
                method: 'POST',
                body: formData
              });

              const result = await response.json();

              if (result.success) {
                this.success = true;
                form.reset();
              } else {
                this.error = result.error || defaultError;
              }
            } catch (err) {
              this.error = networkError;
            } finally {
              this.submitting = false;
            }
          }
        }"
        @submit="submitForm($event)"
        class="px-6 pb-24 pt-28 sm:pb-32 lg:px-8 lg:py-48"
      >
        <div class="mx-auto max-w-xl lg:mr-0 lg:max-w-lg">
          <input type="hidden" name="locale" value={locale} />
          <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label for="name" class="block text-sm font-semibold text-foreground">{t(locale, 'form.name')} *</label>
              <div class="mt-2.5">
                <input
                  id="name"
                  type="text"
                  name="name"
                  autocomplete="name"
                  required
                  class="block w-full rounded-md bg-background px-3.5 py-2 text-base text-foreground outline outline-1 -outline-offset-1 outline-border placeholder:text-muted-foreground focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-ring"
                  placeholder={t(locale, 'home.contact.namePlaceholder')}
                />
              </div>
            </div>

            <div class="sm:col-span-2">
              <label for="email" class="block text-sm font-semibold text-foreground">{t(locale, 'form.email')} *</label>
              <div class="mt-2.5">
                <input
                  id="email"
                  type="email"
                  name="email"
                  autocomplete="email"
                  required
                  class="block w-full rounded-md bg-background px-3.5 py-2 text-base text-foreground outline outline-1 -outline-offset-1 outline-border placeholder:text-muted-foreground focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-ring"
                  placeholder={t(locale, 'home.contact.emailPlaceholder')}
                />
              </div>
            </div>

            <div class="sm:col-span-2">
              <label for="phone" class="block text-sm font-semibold text-foreground">{t(locale, 'form.phone')}</label>
              <div class="mt-2.5">
                <input
                  id="phone"
                  type="tel"
                  name="phone"
                  autocomplete="tel"
                  class="block w-full rounded-md bg-background px-3.5 py-2 text-base text-foreground outline outline-1 -outline-offset-1 outline-border placeholder:text-muted-foreground focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-ring"
                  placeholder={t(locale, 'home.contact.phonePlaceholder')}
                />
              </div>
            </div>

            <div class="sm:col-span-2">
              <label for="vehicle" class="block text-sm font-semibold text-foreground">{t(locale, 'form.vehicle')}</label>
              <div class="mt-2.5">
                <input
                  id="vehicle"
                  type="text"
                  name="vehicle"
                  class="block w-full rounded-md bg-background px-3.5 py-2 text-base text-foreground outline outline-1 -outline-offset-1 outline-border placeholder:text-muted-foreground focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-ring"
                  placeholder={t(locale, 'home.contact.vehiclePlaceholder')}
                />
              </div>
            </div>

            <div class="sm:col-span-2">
              <label for="service" class="block text-sm font-semibold text-foreground">{t(locale, 'form.serviceInterest')}</label>
              <div class="mt-2.5">
                <select
                  id="service"
                  name="service"
                  class="block w-full rounded-md bg-background px-3.5 py-2 text-base text-foreground outline outline-1 -outline-offset-1 outline-border focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-ring"
                >
                  <option value="">{t(locale, 'home.contact.selectService')}</option>
                  <option value="ceramic-coating">طلاء السيراميك</option>
                  <option value="paint-protection-film">فيلم حماية الطلاء (PPF)</option>
                  <option value="polish">تلميع وتصحيح الطلاء</option>
                  <option value="window-film">تظليل النوافذ وأفلام الزجاج</option>
                  <option value="premium-car-wash">غسيل سيارات فاخر</option>
                  <option value="leather-upholstery">العناية بالجلد والتنجيد</option>
                </select>
              </div>
            </div>

            <div class="sm:col-span-2">
              <label for="message" class="block text-sm font-semibold text-foreground">{t(locale, 'form.message')} *</label>
              <div class="mt-2.5">
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="block w-full rounded-md bg-background px-3.5 py-2 text-base text-foreground outline outline-1 -outline-offset-1 outline-border placeholder:text-muted-foreground focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-ring"
                  placeholder="أخبرنا بالخدمة المطلوبة، وحالة السيارة، والموعد المناسب لك."
                ></textarea>
              </div>
            </div>
          </div>

          <div class="mt-8 flex justify-end">
            <Button type="submit" size="lg" className="w-full sm:w-auto" :disabled="submitting">
              <span x-show="!submitting">احصل على عرض السعر</span>
              <span x-show="submitting" x-cloak>{t(locale, 'form.sending')}</span>
              <Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" x-show="!submitting" />
            </Button>
          </div>

          <div
            x-show="success"
            x-cloak
            x-transition
            class="mt-4 rounded-lg border border-green-200 bg-green-50 p-4 text-green-800"
          >
            <p class="font-bold">شكراً لك</p>
            <p class="mt-1 text-sm">سيتواصل فريقنا معك قريباً بعرض سعر مخصص.</p>
          </div>

          <div
            x-show="error"
            x-cloak
            x-transition
            class="mt-4 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800"
            x-text="error"
          >
          </div>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

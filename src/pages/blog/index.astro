---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import GridPattern from '@/components/GridPattern.astro';
import { Card } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Icon } from 'astro-icon/components';

export const prerender = true;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts.find((post) => post.data.featured);
const allPosts = posts;

const breadcrumbs = [
  { name: 'Home', url: 'https://wrpdetailing.ae/' },
  { name: 'Blog', url: 'https://wrpdetailing.ae/blog/' },
];

const categoryLabels: Record<string, string> = {
	guide: 'Guide',
	news: 'News',
	update: 'Update',
	event: 'Event',
	listicle: 'Listicle',
};

const categories = ['all', 'guide', 'listicle', 'news'] as const;
const categoryFilterLabels: Record<string, string> = {
	all: 'All',
	guide: 'Guides',
	listicle: 'Listicles',
	news: 'News',
};

// Track which categories actually have posts (for empty state)
const categoriesWithPosts = new Set(allPosts.map(p => p.data.category));
const categoryHasPosts: Record<string, boolean> = {};
for (const cat of categories) {
	categoryHasPosts[cat] = cat === 'all' ? allPosts.length > 0 : categoriesWithPosts.has(cat);
}

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://wrpdetailing.ae';

// CollectionPage + ItemList schema for blog index
const blogListSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'WRP Dubai Blog',
	description: 'Expert guides on ceramic coating, paint protection film, and car care in Dubai.',
	url: `${siteUrl}/blog/`,
	inLanguage: 'en',
	isPartOf: { '@type': 'WebSite', name: 'WRP Dubai', url: `${siteUrl}/` },
	mainEntity: {
		'@type': 'ItemList',
		numberOfItems: allPosts.length,
		itemListElement: allPosts.map((post, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			url: `${siteUrl}/blog/${post.id}/`,
			name: post.data.title,
		})),
	},
};
---

<BaseLayout
	title="Blog | WRP Dubai - Car Care Insights & Guides"
	description="Expert guides on ceramic coating, paint protection film, and car care in Dubai. Tips from WRP's detailing professionals."
>
	<Breadcrumbs crumbs={breadcrumbs} className="container mx-auto px-6 pt-28" />

	<!-- CollectionPage + ItemList JSON-LD -->
	<script type="application/ld+json" set:html={JSON.stringify(blogListSchema)} />

	<!-- Hero Section -->
	<section class="relative py-20 px-6 bg-black text-white">
		<div class="container mx-auto max-w-7xl text-center">
			<h1 class="font-serif text-5xl md:text-7xl font-bold mb-6">Blog</h1>
			<p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto">
				Expert insights on paint protection, ceramic coating, and automotive care - tailored for Dubai's climate.
			</p>
		</div>
	</section>

	<!-- Featured Post -->
	{featuredPost && (
		<section class="py-20 px-6 bg-muted/30">
			<div class="container mx-auto max-w-7xl">
				<div class="flex items-center gap-3 mb-8">
					<div class="h-px flex-1 bg-border"></div>
					<span class="text-xs uppercase tracking-widest text-muted-foreground font-medium">Featured</span>
					<div class="h-px flex-1 bg-border"></div>
				</div>

				<a href={`/blog/${featuredPost.id}/`} class="group block">
					<div class="grid md:grid-cols-2 gap-8 items-center">
						{featuredPost.data.heroImage && (
							<div class="relative aspect-[16/9] overflow-hidden rounded-lg">
								<img
									src={featuredPost.data.heroImage}
									alt={featuredPost.data.title}
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
								/>
							</div>
						)}
						<div class={featuredPost.data.heroImage ? '' : 'md:col-span-2 max-w-2xl mx-auto text-center'}>
							<div class="flex items-center gap-2 text-xs text-muted-foreground mb-4">
								<span class="uppercase tracking-wider font-medium text-foreground bg-foreground/10 px-2 py-1">
									{categoryLabels[featuredPost.data.category] || featuredPost.data.category}
								</span>
								<span class="text-border">·</span>
								<FormattedDate date={featuredPost.data.pubDate} />
								{featuredPost.data.readingTime && (
									<>
										<span class="text-border">·</span>
										<span>{featuredPost.data.readingTime} min read</span>
									</>
								)}
							</div>
							<h2 class="font-serif text-3xl md:text-4xl font-bold mb-4 group-hover:underline underline-offset-4">
								{featuredPost.data.title}
							</h2>
							<p class="text-muted-foreground leading-relaxed mb-6">
								{featuredPost.data.description}
							</p>
							<span class="inline-flex items-center text-sm font-medium group-hover:underline underline-offset-4">
								Read article
								<Icon name="lucide:arrow-right" class="ml-1 h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" />
							</span>
						</div>
					</div>
				</a>
			</div>
		</section>
	)}

	<!-- Category Filter + Post Grid -->
	<section class="py-20 px-6" x-data={`{ category: 'all', hasPosts: ${JSON.stringify(categoryHasPosts)} }`}>
		<div class="container mx-auto max-w-7xl">
			<!-- Category Filter Bar -->
			<div class="flex flex-wrap gap-2 mb-12 justify-center">
				{categories.map((cat) => (
					<button
						class="px-4 py-2 text-sm tracking-wide border transition-colors"
						:class={`category === '${cat}' ? 'bg-foreground text-background border-foreground' : 'bg-transparent text-foreground border-border hover:border-foreground'`}
						@click={`category = '${cat}'`}
					>
						{categoryFilterLabels[cat]}
					</button>
				))}
			</div>

			<!-- Post Grid -->
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				{allPosts.map((post) => (
					<a
						href={`/blog/${post.id}/`}
						class="group block"
						x-show={`category === 'all' || category === '${post.data.category}'`}
						x-cloak
					>
						<Card className="overflow-hidden h-full hover:shadow-lg transition-all duration-300 p-0">
							{post.data.heroImage && (
								<div class="relative aspect-[16/9] overflow-hidden">
									<img
										src={post.data.heroImage}
										alt={post.data.title}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading="lazy"
									/>
								</div>
							)}
							<div class="p-5">
								<div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
									{post.data.category && (
										<span class="uppercase tracking-wider font-medium text-foreground">
											{categoryLabels[post.data.category] || post.data.category}
										</span>
									)}
									{post.data.category && <span class="text-border">·</span>}
									<FormattedDate date={post.data.pubDate} />
									{post.data.readingTime && (
										<>
											<span class="text-border">·</span>
											<span>{post.data.readingTime} min</span>
										</>
									)}
								</div>
								<h3 class="font-serif text-lg font-bold mb-2 group-hover:underline underline-offset-4 leading-snug">
									{post.data.title}
								</h3>
								<p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
									{post.data.description}
								</p>
								<span class="inline-flex items-center text-sm font-medium mt-4 group-hover:underline underline-offset-4">
									Read article
									<Icon name="lucide:arrow-right" class="ml-1 h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" />
								</span>
							</div>
						</Card>
					</a>
				))}
			</div>

			<!-- Empty state -->
			<!-- Empty state (client-side, for filtered categories with no posts) -->
			<div x-show="!hasPosts[category]" x-cloak class="text-center py-20">
				<div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-muted mb-6">
					<Icon name="lucide:file-text" class="h-7 w-7 text-muted-foreground" />
				</div>
				<h3 class="font-serif text-2xl font-bold mb-3">No posts yet</h3>
				<p class="text-muted-foreground max-w-md mx-auto mb-6">
					We're working on content for this category. Check back soon or explore our other articles.
				</p>
				<button
					class="px-6 py-2.5 text-sm tracking-wide border border-foreground bg-foreground text-background hover:bg-foreground/90 transition-colors"
					@click="category = 'all'"
				>
					View all posts
				</button>
			</div>

			{allPosts.length === 0 && (
				<div class="text-center py-16">
					<p class="text-muted-foreground text-lg">No posts yet. Check back soon.</p>
				</div>
			)}
		</div>
	</section>

	<!-- CTA Section -->
	<section class="relative py-32 px-6 bg-black text-white overflow-hidden">
		<GridPattern />
		<div class="container mx-auto max-w-4xl text-center relative z-10">
			<h2 class="font-serif text-4xl md:text-5xl font-bold mb-6">Stay Informed</h2>
			<p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
				Have questions about protecting your vehicle? Our team is ready to help you choose the right service for your car and Dubai's demanding climate.
			</p>
			<Button size="lg" className="bg-white text-black hover:bg-white/90 cursor-pointer" data-contact-modal>
				GET IN TOUCH
				<Icon name="lucide:arrow-right" class="ml-2 h-5 w-5" />
			</Button>
		</div>
	</section>
</BaseLayout>

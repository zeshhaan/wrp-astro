---
import Navigation from '../components/Navigation.astro';
import WRPFooter from '../components/WRPFooter.astro';
import Schema from '../components/Schema.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import GoogleReviewBadge from '../components/GoogleReviewBadge.astro';
import LanguageBanner from '../components/LanguageBanner.astro';
import { SEO } from 'astro-seo';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';
import { getLocale, getDir, getOgLocale, getAlternateUrl } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  showNav?: boolean;
  showFooter?: boolean;
  ogImage?: string;
  noindex?: boolean;
  includeSchema?: boolean;
  ogType?: 'website' | 'article';
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  author?: string;
  tags?: string[];
  articleSection?: string;
  publisher?: string;
}

const {
  title,
  description,
  showNav = true,
  showFooter = true,
  ogImage = '/og-image.jpg',
  noindex = false,
  includeSchema = true,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  author,
  tags = [],
  articleSection,
  publisher = 'WRP Detailing Studio',
} = Astro.props;

const locale = getLocale(Astro.currentLocale);
const dir = getDir(locale);
const ogLocale = getOgLocale(locale);
const isArabic = locale === 'ar';

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const alternateUrl = new URL(getAlternateUrl(Astro.url.pathname, locale), Astro.site).toString();

// Build Open Graph Article extension meta when applicable
const publishedISO = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const modifiedISO = modifiedTime ? new Date(modifiedTime).toISOString() : undefined;
const articleMeta: Array<{ property: string; content: string }> = [];
if (ogType === 'article') {
  if (publishedISO) articleMeta.push({ property: 'article:published_time', content: publishedISO });
  if (modifiedISO) articleMeta.push({ property: 'article:modified_time', content: modifiedISO });
  if (author) articleMeta.push({ property: 'article:author', content: String(author) });
  if (articleSection) articleMeta.push({ property: 'article:section', content: String(articleSection) });
  if (Array.isArray(tags)) {
    articleMeta.push(...tags.map((tag) => ({ property: 'article:tag', content: String(tag) })));
  }
}

const extendLinks = [
  { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
  { rel: 'icon', type: 'image/x-icon', href: '/favicon.ico' },
  { rel: 'icon', type: 'image/png', sizes: '96x96', href: '/favicon-96x96.png' },
  { rel: 'apple-touch-icon', sizes: '180x180', href: '/apple-touch-icon.png' },
  { rel: 'manifest', href: '/site.webmanifest' },
];

const extendMeta = [
  { name: 'viewport', content: 'width=device-width, initial-scale=1.0' },
  { name: 'theme-color', content: '#000000' },
  { name: 'geo.region', content: 'AE-DU' },
  { name: 'geo.placename', content: 'Dubai' },
  { name: 'geo.position', content: '25.2854;55.3781' },
  { name: 'ICBM', content: '25.2854, 55.3781' },
  ...articleMeta,
  // Twitter does not have direct article:* equivalents; use labels
  ...(ogType === 'article' && articleSection
    ? [
        { name: 'twitter:label1', content: 'Section' },
        { name: 'twitter:data1', content: String(articleSection) },
      ]
    : []),
  ...(ogType === 'article' && publisher
    ? [
        { name: 'twitter:label2', content: 'Publisher' },
        { name: 'twitter:data2', content: String(publisher) },
      ]
    : []),
];
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      openGraph={{
        basic: {
          title: title,
          type: ogType,
          image: ogImageURL,
          url: canonicalURL,
        },
        optional: {
          description: description,
          siteName: 'WRP Detailing Studio',
          locale: ogLocale,
        },
        image: {
          alt: title,
          width: 1200,
          height: 630,
          type: 'image/jpeg',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        site: '@wrp_ae',
        creator: '@wrp_ae',
        title: title,
        description: description,
        image: ogImageURL,
        imageAlt: title,
      }}
      extend={{ link: extendLinks, meta: extendMeta }}
    />

    {includeSchema && <Schema />}
    <Schema type="SiteNavigationElement" />

    <!-- hreflang tags for i18n -->
    <link rel="alternate" hreflang="en-AE" href={isArabic ? alternateUrl : canonicalURL} />
    <link rel="alternate" hreflang="ar-AE" href={isArabic ? canonicalURL : alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={isArabic ? alternateUrl : canonicalURL} />

    <!-- View Transitions Fallback for browsers without native support -->
    <ClientRouter />

    <!-- Fonts — Arabic loaded conditionally -->
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-montserrat" />
    {isArabic && (
      <>
        <Font cssVariable="--font-noto-naskh" preload />
        <Font cssVariable="--font-ibm-plex-arabic" preload />
      </>
    )}

    <!-- Alpine.js loaded via @astrojs/alpinejs integration (no CDN needed) -->

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "u18n0h2k1x");
    </script>

    <style>
      [x-cloak] {
        display: none !important;
      }
    </style>

    <script>
      // Clean up Alpine.js scopes before View Transitions swap to prevent detached DOM leaks.
      // Alpine's MutationObserver may not fire reliably during full-page swap.
      document.addEventListener('astro:before-swap', () => {
        const alpine = (window as Window & {
          Alpine?: { destroyTree: (el: Element) => void };
        }).Alpine;

        if (alpine) {
          // Walk all Alpine-managed elements and trigger their destroy() lifecycle
          document.querySelectorAll('[x-data]').forEach((el) => {
            alpine.destroyTree(el);
          });
        }
      });
    </script>
  </head>
  <body>
    {showNav && <Navigation locale={locale} />}

    <LanguageBanner locale={locale} />

    <slot />

    {showFooter && <WRPFooter locale={locale} />}

    <div transition:persist="google-review-badge">
      <GoogleReviewBadge />
    </div>
    <div transition:persist="whatsapp-button">
      <WhatsAppButton />
    </div>
  </body>
</html>

---
import Navigation from '../components/Navigation.astro';
import WRPFooter from '../components/WRPFooter.astro';
import Schema from '../components/Schema.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import GoogleReviewBadge from '../components/GoogleReviewBadge.astro';
import { SEO } from 'astro-seo';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  showNav?: boolean;
  showFooter?: boolean;
  ogImage?: string;
  noindex?: boolean;
  includeSchema?: boolean;
  ogType?: 'website' | 'article';
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  author?: string;
  tags?: string[];
  articleSection?: string;
  publisher?: string;
}

const {
  title,
  description,
  showNav = true,
  showFooter = true,
  ogImage = '/og-image.jpg',
  noindex = false,
  includeSchema = true,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  author,
  tags = [],
  articleSection,
  publisher = 'WRP Dubai',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();

// Build Open Graph Article extension meta when applicable
const publishedISO = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const modifiedISO = modifiedTime ? new Date(modifiedTime).toISOString() : undefined;
const articleMeta = ogType === 'article'
  ? [
      publishedISO && { property: 'article:published_time', content: publishedISO },
      modifiedISO && { property: 'article:modified_time', content: modifiedISO },
      author && { property: 'article:author', content: String(author) },
      articleSection && { property: 'article:section', content: String(articleSection) },
      ...(Array.isArray(tags) ? tags.map((t) => ({ property: 'article:tag', content: String(t) })) : []),
    ].filter(Boolean)
  : [];

const extendLinks = [
  { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
  { rel: 'icon', type: 'image/x-icon', href: '/favicon.ico' },
  { rel: 'icon', type: 'image/png', sizes: '96x96', href: '/favicon-96x96.png' },
  { rel: 'apple-touch-icon', sizes: '180x180', href: '/apple-touch-icon.png' },
  { rel: 'manifest', href: '/site.webmanifest' },
];

const extendMeta = [
  { name: 'viewport', content: 'width=device-width, initial-scale=1.0' },
  { name: 'theme-color', content: '#000000' },
  { name: 'geo.region', content: 'AE-DU' },
  { name: 'geo.placename', content: 'Dubai' },
  { name: 'geo.position', content: '25.2854;55.3781' },
  { name: 'ICBM', content: '25.2854, 55.3781' },
  ...articleMeta,
  // Twitter does not have direct article:* equivalents; use labels
  ...(ogType === 'article' && articleSection
    ? [
        { name: 'twitter:label1', content: 'Section' },
        { name: 'twitter:data1', content: String(articleSection) },
      ]
    : []),
  ...(ogType === 'article' && publisher
    ? [
        { name: 'twitter:label2', content: 'Publisher' },
        { name: 'twitter:data2', content: String(publisher) },
      ]
    : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      noindex={noindex}
      openGraph={{
        basic: {
          title: title,
          type: ogType,
          image: ogImageURL,
          url: canonicalURL,
        },
        optional: {
          description: description,
          siteName: 'WRP Dubai',
          locale: 'en_AE',
        },
        image: {
          alt: title,
          width: 1200,
          height: 630,
          type: 'image/jpeg',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        site: '@wrp_ae',
        creator: '@wrp_ae',
        title: title,
        description: description,
        image: ogImageURL,
        imageAlt: title,
      }}
      extend={{ link: extendLinks, meta: extendMeta }}
    />

    {includeSchema && <Schema />}
    <Schema type="SiteNavigationElement" />

    <!-- View Transitions Fallback for browsers without native support -->
    <ClientRouter />

    <!-- Astro Experimental Fonts -->
    <Font cssVariable="--font-playfair" preload />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-montserrat" />

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "u18n0h2k1x");
    </script>

    <style>
      [x-cloak] {
        display: none !important;
      }
    </style>
  </head>
  <body>
    {showNav && <Navigation />}

    <slot />

    {showFooter && <WRPFooter />}

    <div transition:persist="google-review-badge">
      <GoogleReviewBadge />
    </div>
    <div transition:persist="whatsapp-button">
      <WhatsAppButton />
    </div>
  </body>
</html>

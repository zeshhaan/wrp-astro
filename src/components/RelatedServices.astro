---
import { getCollection } from 'astro:content';
import { Card } from "@/components/ui/card";
import Icon from '@/components/Icon.astro';
import { getLocale, localizeUrl } from '../i18n/utils';
import { t } from '../i18n/translations';

interface Props {
	serviceIds: string[];
	locale?: string;
}

const locale = getLocale(Astro.props.locale ?? Astro.currentLocale);
const { serviceIds } = Astro.props;

const allServices = await getCollection('services');
// Filter to locale-appropriate services, fallback to English
const localeServices = allServices.filter((s) =>
  locale === 'ar' ? s.id.startsWith('ar/') : !s.id.startsWith('ar/')
);
const related = localeServices
	.filter((s) => serviceIds.includes(s.id.replace(/^ar\//, '')))
	.slice(0, 3);
---

{serviceIds.length > 0 && related.length > 0 && (
<section class="py-24 px-6 bg-muted/20">
	<div class="container mx-auto max-w-7xl">
		<div class="text-center mb-12">
			<h2 class="font-serif text-3xl md:text-4xl font-bold mb-3">{t(locale, 'services.relatedTitle')}</h2>
			<p class="text-muted-foreground max-w-2xl mx-auto">{t(locale, 'services.relatedSubtitle')}</p>
		</div>

		<div class={`grid gap-8 ${related.length === 1 ? 'max-w-lg mx-auto' : related.length === 2 ? 'md:grid-cols-2 max-w-4xl mx-auto' : 'md:grid-cols-3'}`}>
			{related.map((service) => (
				<a href={localizeUrl(`/services/${service.id.replace(/^ar\//, '')}/`, locale)} class="group block">
					<Card className="overflow-hidden h-full hover:shadow-2xl transition-all duration-500 p-0">
						<div class="relative h-64 overflow-hidden">
							<img
								src={service.data.heroImage}
								alt={service.data.title}
								class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
								loading="lazy"
							/>
							<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
							<h3 class="absolute bottom-4 left-6 font-serif text-2xl font-bold text-white">{service.data.title}</h3>
						</div>
						<div class="p-6">
							<p class="text-muted-foreground leading-relaxed mb-6 line-clamp-3">{service.data.description}</p>
							<span class="inline-flex items-center text-sm font-medium group-hover:underline underline-offset-4">
								{t(locale, 'common.learnMore').toUpperCase()}
								<Icon name="lucide:arrow-right" class="ml-2 h-4 w-4 group-hover:translate-x-1 transition-transform" />
							</span>
						</div>
					</Card>
				</a>
			))}
		</div>
	</div>
</section>
)}

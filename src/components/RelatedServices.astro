---
import { getCollection } from 'astro:content';
import { Card } from "@/components/ui/card";
import { Icon } from 'astro-icon/components';
import { getLocale, localizeUrl } from '../i18n/utils';
import { t } from '../i18n/translations';

interface Props {
	serviceIds: string[];
	locale?: string;
}

const locale = getLocale(Astro.props.locale ?? Astro.currentLocale);
const { serviceIds } = Astro.props;

const allServices = await getCollection('services');
// Filter to locale-appropriate services, fallback to English
const localeServices = allServices.filter((s) =>
  locale === 'ar' ? s.id.startsWith('ar/') : !s.id.startsWith('ar/')
);
const related = localeServices
	.filter((s) => serviceIds.includes(s.id.replace(/^ar\//, '')))
	.slice(0, 3);
---

{serviceIds.length > 0 && related.length > 0 && (
<aside class="mt-16 pt-12 border-t border-border">
	<h2 class="font-serif text-2xl md:text-3xl font-bold mb-2">{t(locale, 'services.relatedTitle')}</h2>
	<p class="text-muted-foreground mb-8">{t(locale, 'services.relatedSubtitle')}</p>

	<div class={`grid gap-6 ${related.length === 1 ? 'max-w-md' : related.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-3'}`}>
		{related.map((service) => (
			<a href={localizeUrl(`/services/${service.id.replace(/^ar\//, '')}/`, locale)} class="group block">
				<Card className="overflow-hidden h-full hover:shadow-lg transition-all duration-300 p-0">
					<div class="relative h-48 overflow-hidden">
						<img
							src={service.data.heroImage}
							alt={service.data.title}
							class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
							loading="lazy"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
						<h3 class="absolute bottom-3 left-4 font-serif text-lg font-bold text-white">
							{service.data.title}
						</h3>
					</div>
					<div class="p-4">
						<p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
							{service.data.description}
						</p>
						<span class="inline-flex items-center text-sm font-medium mt-3 group-hover:underline underline-offset-4">
							{t(locale, 'common.learnMore')}
							<Icon name="lucide:arrow-right" class="ml-1 h-3.5 w-3.5 group-hover:translate-x-0.5 transition-transform" />
						</span>
					</div>
				</Card>
			</a>
		))}
	</div>
</aside>
)}

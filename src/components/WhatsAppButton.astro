---
interface Props {
  whatsappLink?: string;
  phoneNumber?: string;
}

const {
  whatsappLink = 'https://dub.sh/wrp-wa',
  phoneNumber = '+971547173000'
} = Astro.props;
---

<!-- Floating WhatsApp Button -->
<button
  id="contact-fab"
  type="button"
  aria-label="Contact us"
  class="whatsapp-button group fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full bg-[#25D366] hover:bg-[#20bd5a] shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110"
>
  <!-- WhatsApp Icon -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="w-7 h-7 text-white"
  >
    <path
      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
    />
  </svg>

  <!-- Tooltip -->
  <span
    class="absolute right-full mr-3 px-3 py-2 bg-foreground text-background text-sm font-medium whitespace-nowrap rounded opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
  >
    Chat with us
  </span>
</button>

<!-- Contact Modal -->
<div
  id="contact-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div class="modal-backdrop absolute inset-0 bg-black/80 backdrop-blur-sm" />

  <!-- Modal Content -->
  <div class="modal-content relative w-full max-w-md transform scale-95 opacity-0 transition-all duration-300 bg-background border border-border shadow-2xl overflow-hidden rounded-lg">
    <!-- Close Button -->
    <button
      id="modal-close"
      class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-muted rounded transition-colors z-10"
      aria-label="Close modal"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Header -->
    <div class="pt-8 pb-4 px-6 text-center border-b border-border">
      <div class="relative inline-flex items-center justify-center mb-4">
        <!-- Sound wave rings -->
        <div class="absolute w-16 h-16 rounded-full border-2 border-primary/30 animate-[sound-wave_2s_ease-out_infinite]"></div>
        <div class="absolute w-16 h-16 rounded-full border-2 border-primary/20 animate-[sound-wave_2s_ease-out_0.6s_infinite]"></div>
        <div class="absolute w-16 h-16 rounded-full border-2 border-primary/10 animate-[sound-wave_2s_ease-out_1.2s_infinite]"></div>
        <!-- Icon circle -->
        <div class="relative w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
            <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" />
          </svg>
        </div>
      </div>
      <h2 id="modal-title" class="font-serif text-2xl font-bold text-foreground">
        Get in Touch
      </h2>
      <p class="mt-2 text-muted-foreground text-sm">
        Our team is ready to assist you
      </p>
    </div>

    <!-- Availability Banner -->
    <div class="border-b border-border px-6 py-3 bg-primary/5">
      <p class="text-center text-sm font-medium text-foreground">
        <span class="inline-block w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
        Available Now — Typical reply in under 2 minutes
      </p>
    </div>

    <!-- Google Review Trust Signal -->
    <div class="border-b border-border px-6 py-3 flex items-center justify-center gap-3 bg-muted/50">
      <!-- Google G Logo -->
      <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <div class="flex gap-0.5">
        {[1,2,3,4,5].map(() => (
          <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <span class="text-sm text-foreground">
        <span class="font-bold">5.0</span>
        <span class="text-muted-foreground">from</span>
        <span class="font-bold">60+</span>
        <span class="text-muted-foreground">Google reviews</span>
      </span>
    </div>

    <!-- Action Buttons -->
    <div class="p-6 space-y-3">
      <!-- WhatsApp Option -->
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 w-full p-4 bg-[#25D366] hover:bg-[#20bd5a] text-white rounded-lg transition-all duration-300 hover:scale-[1.02] hover:shadow-lg"
      >
        <div class="flex-shrink-0 w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div class="flex-1 text-left">
          <span class="block text-lg font-bold tracking-wide">Message on WhatsApp</span>
          <span class="block text-sm text-white/80">Chat with our team instantly</span>
        </div>
        <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>

      <!-- Call Option -->
      <a
        href="https://dub.sh/wrp-phone"
        class="group flex items-center gap-4 w-full p-4 bg-muted hover:bg-muted/80 border border-border text-foreground rounded-lg transition-all duration-300 hover:scale-[1.02] hover:shadow-lg"
      >
        <div class="flex-shrink-0 w-12 h-12 bg-primary/10 border border-primary/20 rounded-full flex items-center justify-center">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <div class="flex-1 text-left">
          <span class="block text-lg font-bold tracking-wide">Call Now</span>
          <span class="block text-sm text-muted-foreground">+971 54 717 3000</span>
        </div>
        <svg class="w-5 h-5 text-muted-foreground group-hover:text-foreground transform group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Footer -->
    <div class="px-6 pb-6">
      <p class="text-center text-xs text-muted-foreground">
        Open daily 9 AM – 9:30 PM (Closed Friday)
      </p>
    </div>
  </div>
</div>

<!-- Pulse animation -->
<style>
  .whatsapp-button::before {
    content: '';
    position: absolute;
    inset: -4px;
    background: #25D366;
    opacity: 0;
    border-radius: 9999px;
    animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    z-index: -1;
  }

  @keyframes pulse-ring {
    0%, 100% {
      opacity: 0;
      transform: scale(1);
    }
    50% {
      opacity: 0.3;
      transform: scale(1.15);
    }
  }

  @keyframes sound-wave {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(1.8);
      opacity: 0;
    }
  }

  #contact-modal.show {
    display: flex;
  }

  #contact-modal.show .modal-content {
    transform: scale(1);
    opacity: 1;
  }

  #contact-modal .modal-backdrop {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #contact-modal.show .modal-backdrop {
    opacity: 1;
  }
</style>

<script>
  const fab = document.getElementById('contact-fab');
  const modal = document.getElementById('contact-modal');
  const closeBtn = document.getElementById('modal-close');
  const backdrop = modal?.querySelector('.modal-backdrop');

  function openModal() {
    modal?.classList.add('show');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.remove('show');
    document.body.style.overflow = '';
  }

  fab?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('show')) {
      closeModal();
    }
  });

  // Any element with data-contact-modal opens the modal
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const modalTrigger = target.closest('[data-contact-modal]');
    if (modalTrigger) {
      e.preventDefault();
      openModal();
    }
  });
</script>

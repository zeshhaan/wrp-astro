---
// Footer component for service and contact pages
---

<footer class="bg-black text-white py-12 px-6">
  <div class="container mx-auto max-w-7xl">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center">
        <img src="/wrp-logo.svg" alt="WRP Logo" class="h-12 w-auto brightness-0 invert" loading="lazy">
      </div>
      <div class="flex gap-8 text-sm">
        <a href="/#services" class="hover:text-white/70 transition-colors">
          Services
        </a>
        <a href="/portfolio/" class="hover:text-white/70 transition-colors">
          Portfolio
        </a>
        <a href="/more-about-wrp/" class="hover:text-white/70 transition-colors">
          About
        </a>
        <a href="/contact-us/" class="hover:text-white/70 transition-colors">
          Contact
        </a>
      </div>
    </div>
    <div class="border-t border-white/10 mt-8 pt-8 text-center text-sm text-white/60">
      <p>&copy; {new Date().getFullYear()} WRP. All rights reserved. <a href="/privacy/" class="hover:text-white/80 transition-colors">Privacy</a> &middot; <a href="/terms/" class="hover:text-white/80 transition-colors">Terms</a></p>
    </div>
  </div>
</footer>

---
import { NAV_PAGES } from '../consts';
import { getCollection } from 'astro:content';
import { getBusiness, getSchemaReviews } from '@/lib/reviews';

const services = await getCollection('services');
const business = getBusiness();
const topReviews = getSchemaReviews(10);
const NAV_SERVICES = services.map((s) => ({ name: s.data.title, href: `/services/${s.id}` }));

interface Props {
  type?: 'LocalBusiness' | 'WebSite' | 'SiteNavigationElement' | 'ServiceCatalog';
}

const { type = 'LocalBusiness' } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://wrpdetailing.ae';
const localBusinessId = `${siteUrl}/#localbusiness`;
const websiteId = `${siteUrl}/#website`;

const serviceCatalogItems = services.map((service, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: service.data.title,
  url: `${siteUrl}/services/${service.id}/`,
  item: {
    '@type': 'Service',
    name: service.data.title,
    serviceType: service.data.title,
    description: service.data.description,
    url: `${siteUrl}/services/${service.id}/`,
  },
}));

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@id': localBusinessId,
  '@type': ['LocalBusiness', 'AutomotiveBusiness'],
  name: 'WRP Dubai',
  alternateName: 'Wrap, Reinforce, Protect',
  description:
    'Premium car detailing studio in Dubai specializing in Paint Protection Film (PPF), ceramic coating, window tinting and window film, car polish and paint correction, leather and upholstery care, and luxury vehicle maintenance',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/wrp-logo.svg`,
    width: 200,
    height: 60,
  },
  image: [
    {
      '@type': 'ImageObject',
      url: `${siteUrl}/og-image.jpg`,
      width: 1200,
      height: 630,
      caption: 'WRP Dubai luxury car detailing studio showroom',
    },
  ],
  telephone: '+971547173000',
  email: 'info@wrpdetailing.ae',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Al Qusais Industrial Area 1',
    addressLocality: 'Dubai',
    addressRegion: 'Dubai',
    addressCountry: 'AE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '25.2854',
    longitude: '55.3781',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Saturday'],
      opens: '09:00',
      closes: '21:30',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Friday'],
      opens: '00:00',
      closes: '00:00',
    },
  ],
  priceRange: 'AED 100 - AED 25000',
  areaServed: [
    { '@type': 'City', name: 'Dubai' },
    { '@type': 'City', name: 'Sharjah' },
    { '@type': 'City', name: 'Ajman' },
    { '@type': 'City', name: 'Abu Dhabi' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'WRP Vehicle Protection and Detailing Services',
    itemListElement: serviceCatalogItems,
  },
  sameAs: [
    'https://dub.sh/wrp_ig',
    'https://dub.sh/wrp-map',
    'https://ggl.link/wrp-review',
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: business.rating.toString(),
    reviewCount: business.totalReviews.toString(),
    bestRating: '5',
    worstRating: '1',
  },
  review: topReviews.map(r => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: r.reviewerName },
    reviewRating: { '@type': 'Rating', ratingValue: r.stars.toString(), bestRating: '5' },
    reviewBody: r.text.slice(0, 500),
  })),
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@id': websiteId,
  '@type': 'WebSite',
  name: 'WRP Dubai',
  alternateName: 'WRP',
  description:
    'Dubai vehicle protection and detailing studio for PPF, window tinting, ceramic coating, car polish, and upholstery care.',
  url: `${siteUrl}/`,
  publisher: { '@id': localBusinessId },
};

const navItems = [...NAV_SERVICES, ...NAV_PAGES];
const siteNavigationSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: navItems.map((item, index) => ({
    '@type': 'SiteNavigationElement',
    position: index + 1,
    name: item.name,
    url: `${siteUrl}${item.href.endsWith('/') ? item.href : item.href + '/'}`,
  })),
};

const serviceCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'WRP Service Catalog',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: serviceCatalogItems.length,
  itemListElement: serviceCatalogItems,
};

const schemas = {
  LocalBusiness: localBusinessSchema,
  WebSite: webSiteSchema,
  SiteNavigationElement: siteNavigationSchema,
  ServiceCatalog: serviceCatalogSchema,
};
const schema = schemas[type];
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

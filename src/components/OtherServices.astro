---
import { Card } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Icon } from 'astro-icon/components';
import { getLocale, localizeUrl } from '../i18n/utils';
import { getBaseSlug, getLocalizedServices } from '../i18n/content';
import { t } from '../i18n/translations';

interface Props {
  currentService: string;
  locale?: string;
}

const locale = getLocale(Astro.props.locale ?? Astro.currentLocale);
const { currentService } = Astro.props;
const localeServices = await getLocalizedServices(locale);
const otherServices = localeServices
  .filter((service) => getBaseSlug(service.id) !== currentService)
  .slice(0, 3)
  .map((service) => ({
    name: service.data.title,
    slug: getBaseSlug(service.id),
    description: service.data.description,
    imageSrc: service.data.heroImage,
  }));
---

<section class="py-32 px-6 bg-muted/20">
  <div class="container mx-auto max-w-7xl">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4">{t(locale, 'services.otherServices')}</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">
        {t(locale, 'services.otherSubtitle')}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {otherServices.map((service) => (
        <Card className="overflow-hidden group hover:shadow-2xl transition-all duration-500 p-0">
          <div class="relative h-64 overflow-hidden">
            <img
              src={service.imageSrc}
              alt={service.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
            <h3 class="absolute bottom-4 left-6 font-serif text-2xl font-bold text-white">{service.name}</h3>
          </div>
          <div class="p-6">
            <p class="text-muted-foreground leading-relaxed mb-6">{service.description}</p>
            <a href={localizeUrl(`/services/${service.slug}/`, locale)}>
              <Button variant="outline" className="w-full group/btn bg-transparent">
                {t(locale, 'common.learnMore').toUpperCase()}
                <Icon name="lucide:arrow-right" class="ml-2 h-4 w-4 group-hover/btn:translate-x-1 transition-transform" />
              </Button>
            </a>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>

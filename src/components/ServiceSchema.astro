---
interface Props {
  serviceName: string;
  serviceType: string;
  description: string;
  lowPrice?: number;
  highPrice?: number;
  serviceUrl: string;
}

const { serviceName, serviceType, description, lowPrice, highPrice, serviceUrl } = Astro.props;

const hasPricing = lowPrice != null && highPrice != null;

const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  url: serviceUrl,
  mainEntityOfPage: serviceUrl,
  serviceType: serviceType,
  name: `${serviceName} Dubai`,
  description: description,
  provider: {
    '@id': 'https://wrpdetailing.ae/#localbusiness',
    '@type': 'LocalBusiness',
    name: 'WRP Detailing Studio',
    url: 'https://wrpdetailing.ae',
  },
  areaServed: [
    {
      '@type': 'City',
      name: 'Dubai',
    },
    {
      '@type': 'City',
      name: 'Sharjah',
    },
    {
      '@type': 'City',
      name: 'Ajman',
    },
  ],
};

if (hasPricing) {
  schema.offers = {
    '@type': 'AggregateOffer',
    url: serviceUrl,
    lowPrice: lowPrice.toString(),
    highPrice: highPrice.toString(),
    priceCurrency: 'AED',
    availability: 'https://schema.org/InStock',
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

---
import { getBusiness, getDisplayCount } from '@/lib/reviews';

interface Props {
  rating?: string;
  reviewCount?: string;
  googleReviewUrl?: string;
}

const business = getBusiness();
const {
  rating = business.rating.toFixed(1),
  reviewCount = getDisplayCount(),
  googleReviewUrl = 'https://dub.sh/wrp-map'
} = Astro.props;
---

<!-- Mobile-only floating Google review badge (hidden until user scrolls past hero) -->
<a
  id="floating-review-badge"
  href={googleReviewUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${rating} stars on Google Reviews`}
  class="fixed bottom-6 left-6 z-50 lg:hidden flex items-center gap-2 bg-black/60 backdrop-blur-sm border border-white/15 px-3 py-2 rounded-full shadow-lg hover:shadow-xl hover:bg-black/70 hover:scale-105 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
>
  <!-- Google G Logo -->
  <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
  </svg>

  <!-- Stars -->
  <div class="flex gap-0.5">
    {[1,2,3,4,5].map(() => (
      <svg class="w-3 h-3 text-yellow-400 fill-current" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  <!-- Review count -->
  <span class="font-bold text-sm text-white">{reviewCount} reviews</span>
</a>

<script>
  // Show floating badge only after scrolling past the hero section
  let badgeScrollHandler: ((e: Event) => void) | null = null;

  function initBadge() {
    if (badgeScrollHandler) {
      window.removeEventListener('scroll', badgeScrollHandler);
      badgeScrollHandler = null;
    }

    const badge = document.getElementById('floating-review-badge');
    if (!badge) return;

    const heroBg = document.getElementById('hero-bg');

    // If no hero on this page, show badge immediately
    if (!heroBg) {
      badge.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      return;
    }

    badgeScrollHandler = () => {
      const heroBottom = heroBg.getBoundingClientRect().bottom;
      if (heroBottom < 0) {
        badge.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      } else {
        badge.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      }
    };

    window.addEventListener('scroll', badgeScrollHandler, { passive: true });
    // Check initial state
    badgeScrollHandler(new Event('scroll'));
  }

  // Astro v6: astro:page-load no longer fires on initial load
  initBadge();
  document.addEventListener('astro:page-load', initBadge);
</script>

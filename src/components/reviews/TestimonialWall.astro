---
/**
 * Full testimonial wall with:
 * 1. Stats hero bar
 * 2. Dual marquee rows (opposite directions)
 * 3. Masonry grid of all reviews with images, highlights, <mark>
 */
import { getAllReviews, getReviewsWithImages, getBusiness, getMarqueeReviews, getDisplayCount } from '@/lib/reviews';
import ReviewCard from './ReviewCard.astro';
import StarRating from './StarRating.astro';
import { getLocale, localizeUrl, toLocalNum as _toLocalNum } from '@/i18n/utils';
import { t } from '@/i18n/translations';

const locale = getLocale(Astro.currentLocale);
const business = getBusiness();
const displayCount = getDisplayCount();
const allReviews = getAllReviews();
const reviewsWithImages = getReviewsWithImages();
const marqueeReviews = getMarqueeReviews();
const toLocalNum = (n: string | number) => _toLocalNum(n, locale);

// Split marquee into two rows
const mid = Math.ceil(marqueeReviews.length / 2);
const row1 = marqueeReviews.slice(0, mid);
const row2 = marqueeReviews.slice(mid);

// Masonry: interleave image reviews throughout
const textOnlyReviews = allReviews.filter(r => !r.localImages?.length && r.text.length > 30);
---

{/* Stats Hero */}
<section class="py-20 px-6 bg-black text-white">
  <div class="container mx-auto max-w-4xl text-center">
    <div class="flex items-center justify-center gap-3 mb-8">
      <svg class="w-8 h-8" viewBox="0 0 24 24">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <span class="text-4xl font-bold">{toLocalNum(business.rating.toFixed(1))}</span>
      <StarRating rating={5} size="lg" />
    </div>
    <h1 class="font-serif text-5xl md:text-7xl font-bold mb-4">{t(locale, 'reviews.whatClientsSay')}</h1>
    <p class="text-white/60 text-lg mb-10">
      {toLocalNum(displayCount)} {t(locale, 'reviews.verifiedOnGoogle')}
    </p>
    <div class="grid grid-cols-3 gap-8 max-w-md mx-auto">
      <div>
        <div class="text-3xl font-bold">{toLocalNum(displayCount)}</div>
        <div class="text-xs text-white/50 uppercase tracking-wider mt-1">{t(locale, 'reviews.reviews')}</div>
      </div>
      <div>
        <div class="text-3xl font-bold">{toLocalNum('5.0')}</div>
        <div class="text-xs text-white/50 uppercase tracking-wider mt-1">{t(locale, 'reviews.statsRating')}</div>
      </div>
      <div>
        <div class="text-3xl font-bold">{toLocalNum('100%')}</div>
        <div class="text-xs text-white/50 uppercase tracking-wider mt-1">{t(locale, 'reviews.statsFiveStar')}</div>
      </div>
    </div>
  </div>
</section>

{/* Marquee Rows */}
<section class="py-16 overflow-hidden bg-muted/30" aria-label={t(locale, 'reviews.scrollingLabel')}>
  {/* Row 1 — scrolls left */}
  <div class="marquee-container mb-6">
    <div class="marquee-row marquee-left">
      {[...row1, ...row1].map((review) => (
        <div class="w-[340px] flex-shrink-0">
          <ReviewCard
            review={review}
            variant="compact"
            showImages={false}
            maxTextLength={150}
            highlightWords={review.highlightQuote ? [review.highlightQuote] : []}
            locale={locale}
          />
        </div>
      ))}
    </div>
  </div>

  {/* Row 2 — scrolls right */}
  <div class="marquee-container">
    <div class="marquee-row marquee-right">
      {[...row2, ...row2].map((review) => (
        <div class="w-[340px] flex-shrink-0">
          <ReviewCard
            review={review}
            variant="compact"
            showImages={false}
            maxTextLength={150}
            highlightWords={review.highlightQuote ? [review.highlightQuote] : []}
            locale={locale}
          />
        </div>
      ))}
    </div>
  </div>
</section>

{/* Masonry Grid — Image Reviews */}
{reviewsWithImages.length > 0 && (
  <section class="py-24 px-6">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-16">
        <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4">{t(locale, 'reviews.seeResults')}</h2>
        <p class="text-muted-foreground">{t(locale, 'reviews.customerPhotos')}</p>
      </div>
      <div class="review-masonry">
        {reviewsWithImages.map((review) => (
          <div class="mb-6 break-inside-avoid">
            <ReviewCard
              review={review}
              variant="featured"
              showImages={true}
              maxTextLength={400}
              highlightWords={review.highlightQuote ? [review.highlightQuote] : []}
              locale={locale}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{/* All Reviews Grid */}
<section class="py-24 px-6 bg-muted/20">
  <div class="container mx-auto max-w-6xl">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4">{t(locale, 'reviews.allReviews')}</h2>
      <p class="text-muted-foreground">{t(locale, 'reviews.everyReview')}</p>
    </div>

    <div class="review-masonry" x-data="{ showAll: false }">
      {textOnlyReviews.slice(0, 12).map((review) => (
        <div class="mb-6 break-inside-avoid">
          <ReviewCard
            review={review}
            variant="default"
            showImages={false}
            maxTextLength={250}
            locale={locale}
          />
        </div>
      ))}

      {/* Hidden remaining reviews */}
      {textOnlyReviews.length > 12 && (
        <>
          <template x-if="showAll">
            <div class="contents">
              {textOnlyReviews.slice(12).map((review) => (
                <div class="mb-6 break-inside-avoid">
                  <ReviewCard
                    review={review}
                    variant="default"
                    showImages={false}
                    maxTextLength={250}
                    locale={locale}
                  />
                </div>
              ))}
            </div>
          </template>

          <div class="col-span-full text-center mt-8" x-show="!showAll">
            <button
              x-on:click="showAll = true"
              class="inline-flex items-center gap-2 px-8 py-3 border border-border hover:border-foreground text-sm font-medium tracking-widest transition-colors duration-300"
            >
              {t(locale, 'reviews.showAll')} {toLocalNum(textOnlyReviews.length)} {t(locale, 'reviews.reviewsLabel')}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </>
      )}
    </div>
  </div>
</section>

{/* Final CTA */}
<section class="py-20 px-6 bg-black text-white text-center">
  <div class="container mx-auto max-w-2xl">
    <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">{t(locale, 'reviews.readyDifference')}</h2>
    <p class="text-white/60 mb-8">
      {locale === 'ar'
        ? `انضم إلى ${toLocalNum(displayCount)} من العملاء الراضين الذين يثقون بـ WRP للعناية بسياراتهم.`
        : `Join ${displayCount} satisfied customers who trust WRP with their vehicles.`}
    </p>
    <a
      href={localizeUrl('/contact-us/', locale)}
      class="inline-flex items-center gap-2 bg-white text-black px-8 py-3 font-medium text-sm tracking-widest hover:bg-white/90 transition-colors"
    >
      {t(locale, 'home.hero.getQuote')}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 chevron-rtl" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</section>

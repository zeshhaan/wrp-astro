---
/**
 * Service-specific reviews section. Shows reviews tagged for a particular service.
 * Falls back to generic reviews if not enough service-specific ones exist.
 */
import { getReviewsForService, getBusiness, getDisplayCount } from '@/lib/reviews';
import ReviewCard from './ReviewCard.astro';

interface Props {
  serviceSlug: string;
  limit?: number;
  heading?: string;
}

const { serviceSlug, limit = 4, heading } = Astro.props;
const reviews = getReviewsForService(serviceSlug).slice(0, limit);
const business = getBusiness();
const displayCount = getDisplayCount();
---

{reviews.length > 0 && (
<section class="py-24 px-6">
  <div class="container mx-auto max-w-6xl">
    <div class="text-center mb-16">
      <div class="flex items-center justify-center gap-2 mb-4">
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        <span class="text-lg font-bold">{business.rating.toFixed(1)}</span>
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3.5 h-3.5 text-yellow-400">
              <path fill-rule="evenodd" d="M8 1.75a.75.75 0 0 1 .692.462l1.41 3.393 3.664.293a.75.75 0 0 1 .428 1.317l-2.791 2.39.853 3.575a.75.75 0 0 1-1.12.814L7.998 12.08l-3.135 1.915a.75.75 0 0 1-1.12-.814l.852-3.574-2.79-2.39a.75.75 0 0 1 .427-1.318l3.663-.293 1.41-3.393A.75.75 0 0 1 8 1.75Z" clip-rule="evenodd" />
            </svg>
          ))}
        </div>
        <span class="text-sm text-muted-foreground">{displayCount} reviews</span>
      </div>
      <h2 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        {heading || 'What Our Clients Say'}
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto">
        Real reviews from verified Google customers
      </p>
    </div>

    <div class="columns-1 md:columns-2 gap-6">
      {reviews.map((review) => (
        <div class="mb-6 break-inside-avoid">
          <ReviewCard
            review={review}
            variant="default"
            showImages={true}
            maxTextLength={300}
          />
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="/reviews/"
        class="inline-flex items-center gap-2 text-sm tracking-widest text-muted-foreground hover:text-foreground transition-colors duration-300 border-b border-border hover:border-foreground pb-1"
      >
        SEE ALL REVIEWS
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
)}
